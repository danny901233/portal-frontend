								"value": "{{API_KEY}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"branchName\": \"Manchester Motors\",\n  \"contactName\": \"John Smith\",\n  \"contactEmail\": \"john@manchestermotors.com\",\n  \"websiteUrl\": \"https://manchestermotors.com\",\n  \"agentType\": \"assist\",\n  \"subscriptionCostGbp\": 400,\n  \"includedMinutes\": 400,\n  \"trialType\": \"days\",\n  \"trialDays\": 14,\n  \"autoPurchaseTwilioNumber\": true,\n  \"activateTwilio\": true\n}"
						},
						"url": {
							"raw": "{{BASE_URL}}/api/onboarding/create-business",
							"host": [
								"{{BASE_URL}}"
							],
							"path": [
								"api",
								"onboarding",
								"create-business"
							]
						},
						"description": "Creates a new business with a 14-day trial period. The subscription will activate automatically after 14 days. This is the most common onboarding flow."
					},
					"response": []
				},
