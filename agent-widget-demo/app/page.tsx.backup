                      Timezone <span className="text-red-500">*</span>
                    </label>
                    <select className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-receptionmate-500 focus:border-transparent outline-none bg-white">
                      <option>GMT+00:00 Europe/London (GMT)</option>
                      <option>GMT-05:00 America/New_York (EST)</option>
                      <option>GMT-08:00 America/Los_Angeles (PST)</option>
                    </select>
                    <p className="mt-1 text-xs text-gray-500">Select the timezone for your AI agent</p>
                  </div>

                  {/* Greeting Message Configuration */}
                  <div className="pt-6 border-t border-gray-200">
                    <h2 className="text-lg font-semibold text-gray-900 mb-4">Greeting Message</h2>

                    {/* Agent's Initial Message */}
                    <div>
                      <label className="block text-sm font-medium text-gray-900 mb-2">
                        Agent's Initial Message <span className="text-red-500">*</span>
                      </label>
                      <div className="relative">
                        <textarea
                          rows={4}
                          defaultValue="Hey, you have reached ReceptionMate. How can I help you today?"
                          className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-receptionmate-500 focus:border-transparent outline-none resize-none"
                        />
                        <div className="absolute bottom-3 right-3 flex items-center gap-2">
                          <span className="text-xs text-gray-400">62 / 190</span>
                          <button className="text-gray-400 hover:text-gray-600">
                            <svg className="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                            </svg>
                          </button>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Actions */}
                  <div className="flex justify-end gap-3 pt-6 border-t border-gray-200">
                    <button
                      onClick={() => setShowModal(true)}
                      className="px-6 py-2.5 text-gray-700 hover:bg-gray-100 rounded-lg font-medium transition-colors"
                    >
                      Cancel
                    </button>
                    <button 
                      onClick={() => setCurrentStep(2)}
                      className="px-6 py-2.5 bg-receptionmate-600 hover:bg-receptionmate-700 text-white rounded-lg font-medium shadow-sm transition-all"
                    >
                      Next: Agent Goals
                    </button>
                  </div>
                </div>
              )}
            </div>

            {/* Right Column - Test Your Agent Panel - Only on Step 3 */}
            {currentStep === 3 && (
            <div className="lg:col-span-1">
              <div className="bg-gradient-to-br from-receptionmate-500 to-receptionmate-600 rounded-lg shadow-lg p-6 text-white sticky top-6">
                <h3 className="text-xl font-semibold mb-6">Test Your Agent</h3>

                {/* Call Type Selection */}
                <div className="mb-6">
                  <p className="text-sm font-medium mb-3">Choose Call Type</p>
                  <div className="grid grid-cols-2 gap-3">
                    <button className="bg-white text-receptionmate-600 px-4 py-3 rounded-lg font-medium text-sm hover:bg-receptionmate-50 transition-colors flex items-center justify-center gap-2">
                      <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                      </svg>
                      Phone Call
                    </button>
                    <button className="bg-receptionmate-700 text-white px-4 py-3 rounded-lg font-medium text-sm hover:bg-receptionmate-800 transition-colors flex items-center justify-center gap-2 border border-receptionmate-500">
                      <svg className="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/>
                      </svg>
                      Web Call
                    </button>
                  </div>
                </div>

                {/* Phone Icon */}
                <div className="flex justify-center mb-6">
                  <div className="w-20 h-20 bg-white/20 rounded-full flex items-center justify-center">
                    <svg className="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                    </svg>
                  </div>
                </div>

                <p className="text-center font-medium mb-6">Test Your Agent</p>

                {/* Phone Number Inputs */}
                <div className="space-y-4 mb-6">
                  <div>
                    <label className="block text-sm font-medium mb-2">
                      Select The Number To Call From <span className="text-red-300">*</span>
                    </label>
                    <input
                      type="text"
                      placeholder="+447426943017"
                      className="w-full px-3 py-2 rounded-lg bg-white/90 text-gray-900 placeholder-gray-500 outline-none focus:ring-2 focus:ring-white"
                    />
                  </div>

                  <div>
                    <label className="block text-sm font-medium mb-2">
                      Enter The Number To Receive The Call <span className="text-red-300">*</span>
                    </label>
                    <input
                      type="text"
                      placeholder="+1 (555) 000-0000"
                      className="w-full px-3 py-2 rounded-lg bg-white/90 text-gray-900 placeholder-gray-500 outline-none focus:ring-2 focus:ring-white"
                    />
                  </div>
                </div>

                {/* Call Me Button */}
                <button className="w-full bg-white text-receptionmate-600 py-3 rounded-lg font-medium hover:bg-receptionmate-50 transition-colors flex items-center justify-center gap-2 mb-4">
                  <svg className="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                  </svg>
                  Call Me
                </button>

                <p className="text-center text-sm">(10 minutes left today)</p>

                {/* Call History */}
                <div className="mt-6">
                  <p className="text-sm font-medium mb-2">Call History</p>
                  <select className="w-full px-3 py-2 rounded-lg bg-white/90 text-gray-500 outline-none">
                    <option>Choose date to view history</option>
                  </select>
                </div>
              </div>
            </div>
            )}
          </div>
        </div>
      )}
    </main>
  );
}
