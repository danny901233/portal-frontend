---
// Shared template for the /alternatives/[slug] competitor-comparison pages.
// Rendered by both the EN page (src/pages/alternatives/[slug].astro) and the
// FR page (src/pages/fr/alternatives/[slug].astro). Locale is derived from the
// URL, so the same component serves both trees.
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyUs from '../components/WhyUs.astro';
import type { Competitor } from '../data/competitors';
import { getLang, L } from '../i18n/ui';

interface Props {
  competitor: Competitor;
}

const { competitor } = Astro.props;
const { displayName, category } = competitor;
const lang = getLang(Astro.url);

const isHumanService = category === 'human-service';

const oneLiner = lang === 'fr' ? competitor.oneLinerFr : competitor.oneLiner;
const whyConsiderAlternative =
  lang === 'fr' ? competitor.whyConsiderAlternativeFr : competitor.whyConsiderAlternative;

const c = {
  en: {
    seoTitle: `${displayName} alternative for UK garages — ReceptionMate`,
    seoDescription: `Looking for a ${displayName} alternative? See why UK garages switch to ReceptionMate — the AI receptionist built specifically for automotive.`,
    eyebrow: `${displayName} alternative`,
    headline: `ReceptionMate vs ${displayName}`,
    getStarted: 'Get started',
    caseStudiesCta: 'See garage case studies',
    whySwitchEyebrow: 'Why garages switch',
    whySwitchHeading: `Four reasons UK garages move from ${displayName} to ReceptionMate.`,
    ctaHeading: `Stop losing bookings to ${displayName}.`,
    ctaBody:
      "No contract. You keep your existing number — we set up call forwarding so the AI catches the calls your team can't get to and answers everything out of hours.",
    reasonsToSwitch: isHumanService
      ? [
          {
            title: "Costs don't scale with call volume",
            body: `Human services like ${displayName} charge per call or per minute — busy Mondays and MOT-due weeks send your bill spiking. ReceptionMate is flat-fee.`,
          },
          {
            title: 'Books straight into Garage Hive & Tyresoft',
            body: 'No more "we\'ll get a message to you" — the booking lands in your diary while the customer\'s still on the line.',
          },
          {
            title: 'Automotive vocabulary, not generic',
            body: 'MOT, interim, cambelt, DPF, EGR, advisories — ReceptionMate already knows them. No need to spell out what an A-service is.',
          },
          {
            title: '24/7 including bank holidays',
            body: 'Most human services charge premium tiers for out-of-hours. ReceptionMate answers every call at the same flat rate, all year.',
          },
        ]
      : [
          {
            title: 'Built for UK automotive from day one',
            body: `${displayName} is a horizontal product retrofitted with a garage preset. ReceptionMate is the only AI receptionist designed specifically for UK garages.`,
          },
          {
            title: 'Handles UK reg plates and accents',
            body: 'Trained on real UK garage calls — Scouse, Glaswegian, West Country, you name it. Captures number plates first time.',
          },
          {
            title: 'Books straight into Garage Hive & Tyresoft',
            body: 'Live DMS integration during the call, not a CSV export at midnight.',
          },
          {
            title: 'DVLA vehicle lookup and MOT history built in',
            body: 'Caller gives the reg, ReceptionMate pulls make, model, year, tax and MOT status — and uses it to quote the right service.',
          },
        ],
  },
  fr: {
    seoTitle: `Alternative à ${displayName} pour les garages — ReceptionMate`,
    seoDescription: `Vous cherchez une alternative à ${displayName} ? Découvrez pourquoi les garages choisissent ReceptionMate — la réceptionniste IA conçue spécifiquement pour l'automobile.`,
    eyebrow: `Alternative à ${displayName}`,
    headline: `ReceptionMate vs ${displayName}`,
    getStarted: 'Commencer',
    caseStudiesCta: 'Voir les études de cas de garages',
    whySwitchEyebrow: 'Pourquoi les garages changent',
    whySwitchHeading: `Quatre raisons pour lesquelles les garages passent de ${displayName} à ReceptionMate.`,
    ctaHeading: `Ne perdez plus de réservations à cause de ${displayName}.`,
    ctaBody:
      "Sans engagement. Vous gardez votre numéro actuel — nous mettons en place le renvoi d'appel pour que l'IA capte les appels que votre équipe ne peut pas prendre et réponde à tout en dehors des heures d'ouverture.",
    reasonsToSwitch: isHumanService
      ? [
          {
            title: "Les coûts n'augmentent pas avec le volume d'appels",
            body: `Les services humains comme ${displayName} facturent à l'appel ou à la minute — les lundis chargés et les semaines de contrôle technique font grimper votre facture. ReceptionMate applique un forfait fixe.`,
          },
          {
            title: 'Réservations directes dans Garage Hive et Tyresoft',
            body: "Fini le « nous vous transmettrons un message » — la réservation arrive dans votre agenda pendant que le client est encore en ligne.",
          },
          {
            title: 'Un vocabulaire automobile, pas générique',
            body: 'Contrôle technique, révision intermédiaire, courroie de distribution, FAP, vanne EGR, points de contrôle — ReceptionMate les connaît déjà. Pas besoin d\'expliquer ce qu\'est une révision de type A.',
          },
          {
            title: '24h/24 et 7j/7, jours fériés compris',
            body: "La plupart des services humains facturent des tarifs majorés en dehors des heures d'ouverture. ReceptionMate répond à chaque appel au même tarif fixe, toute l'année.",
          },
        ]
      : [
          {
            title: "Conçu pour l'automobile britannique dès le premier jour",
            body: `${displayName} est un produit horizontal adapté après coup avec un préréglage « garage ». ReceptionMate est la seule réceptionniste IA conçue spécifiquement pour les garages.`,
          },
          {
            title: 'Gère les plaques et accents britanniques',
            body: "Entraînée sur de vrais appels de garages britanniques — accent de Liverpool, de Glasgow, du sud-ouest, et bien d'autres. Elle capte les plaques d'immatriculation du premier coup.",
          },
          {
            title: 'Réservations directes dans Garage Hive et Tyresoft',
            body: "Intégration DMS en direct pendant l'appel, pas un export CSV à minuit.",
          },
          {
            title: 'Consultation véhicule DVLA et historique de contrôle technique intégrés',
            body: "L'appelant donne la plaque, ReceptionMate récupère la marque, le modèle, l'année, la taxe et le statut du contrôle technique — et s'en sert pour proposer la bonne prestation.",
          },
        ],
  },
}[lang];
---

<BaseLayout title={c.seoTitle} description={c.seoDescription}>

  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 h-96 w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-5xl px-4 pt-16 pb-12 sm:px-6 lg:px-8 lg:pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">
        {c.eyebrow}
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        {c.headline}
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-ink-700">
        {oneLiner}
      </p>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-600">
        {whyConsiderAlternative}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href={L('/get-started', lang)}
          class="inline-flex items-center justify-center rounded-md bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition"
        >
          {c.getStarted}
        </a>
        <a
          href={L('/case-studies', lang)}
          class="inline-flex items-center justify-center rounded-md border border-ink-300 px-5 py-3 text-sm font-semibold text-ink-700 hover:border-ink-400 transition"
        >
          {c.caseStudiesCta}
        </a>
      </div>
    </div>
  </section>

  <!-- Why switch -->
  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.whySwitchEyebrow}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
          {c.whySwitchHeading}
        </h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {c.reasonsToSwitch.map((r) => (
          <div class="rounded-2xl border border-ink-200 bg-white p-6">
            <h3 class="text-lg font-semibold text-ink-900">{r.title}</h3>
            <p class="mt-2 text-base leading-relaxed text-ink-700">{r.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table — reuses the homepage comparison so the messaging
       stays consistent across the site. -->
  <WhyUs />

  <!-- CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-brand-600 p-10 text-center sm:p-14">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {c.ctaHeading}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
          {c.ctaBody}
        </p>
        <div class="mt-8">
          <a
            href={L('/get-started', lang)}
            class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow-sm hover:bg-brand-50 transition"
          >
            {c.getStarted}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
