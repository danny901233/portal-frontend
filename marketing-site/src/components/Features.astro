---
const features = [
  {
    title: 'Books straight into your diary',
    body: 'Integrates with Garage Hive, HubSpot, and other booking systems. Slots are reserved in real time so no double-bookings, ever.',
    icon: 'calendar',
  },
  {
    title: 'Knows your services and prices',
    body: 'Trained on your menu — MOTs, services, diagnostics, tyres. Quotes prices on the spot when you let it.',
    icon: 'sparkles',
  },
  {
    title: 'Captures every detail',
    body: 'Customer name, vehicle reg, service requested, preferred time, callback number. All in one place in the portal.',
    icon: 'clipboard',
  },
  {
    title: 'SMS confirmations & reminders',
    body: 'Customer gets a confirmation text right after the call. Reminder the day before. No more no-shows.',
    icon: 'phone',
  },
  {
    title: 'Escalates when it should',
    body: 'Complex enquiries, complaints, or VIP customers get put through to a human. You stay in control.',
    icon: 'shield',
  },
  {
    title: 'Reports on what matters',
    body: 'Calls answered, bookings captured, revenue won, abandoned reasons. Weekly summary straight to your inbox.',
    icon: 'chart',
  },
];

const iconMap: Record<string, string> = {
  calendar: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  sparkles: 'M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z',
  clipboard: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
  phone: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  shield: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
  chart: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
};
---

<section class="bg-ink-50 py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">What's in the box</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Built for the way garages actually run.
      </h2>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-2xl border border-ink-200 bg-white p-6 transition hover:border-brand-300 hover:shadow-md hover:shadow-brand-900/5">
          <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[f.icon]} />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-ink-900">{f.title}</h3>
          <p class="mt-2 text-base text-ink-600">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
