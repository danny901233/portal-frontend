---
// Hero - CTA-led; the garage lookup typeahead lives at step 1 of the /get-started wizard.
import { getLang, L } from '../i18n/ui';
const lang = getLang(Astro.url);
const c = {
  en: {
    badge: 'Built for UK garages',
    h1a: 'The automotive', h1b: 'AI receptionist.',
    sub: 'ReceptionMate answers every call, captures the booking, and sends it straight to your team. 24/7.',
    getStarted: 'Start your free trial',
    seeHow: 'See how it works',
    billing: '14-day free trial on Assist · then £200/mo',
    trusted: 'trusted by 23+ UK garages',
    demoPrompt: 'Not ready to sign up?',
    demoCta: 'Book a free demo',
    demoTier: 'a demo',
  },
  fr: {
    badge: 'Conçu pour les garages',
    h1a: 'La réceptionniste IA', h1b: 'pour l’automobile.',
    sub: 'ReceptionMate répond à chaque appel, enregistre la réservation et la transmet directement à votre équipe. 24h/24, 7j/7.',
    getStarted: 'Démarrer votre essai gratuit',
    seeHow: 'Voir comment ça marche',
    billing: 'Essai gratuit 14 jours sur Assist · puis 200 £/mois',
    trusted: 'adopté par plus de 23 garages',
    demoPrompt: 'Pas encore prêt à vous inscrire ?',
    demoCta: 'Réservez une démo gratuite',
    demoTier: 'votre démo',
  },
}[lang];
---

<section class="relative isolate overflow-hidden bg-white">
  <!-- subtle brand glow -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute -top-40 left-1/2 h-96 w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"></div>
    <div class="absolute top-20 -left-32 h-72 w-72 rounded-full bg-brand-200/30 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-7xl px-4 pt-12 pb-16 sm:px-6 sm:pt-16 lg:px-8 lg:pt-24 lg:pb-24">
    <div class="mx-auto max-w-3xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
        {c.badge}
      </div>

      <h1 class="mt-6 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        {c.h1a}<br />
        <span class="text-brand-600">{c.h1b}</span>
      </h1>

      <p class="mx-auto mt-5 max-w-xl text-base leading-relaxed text-ink-600 sm:text-lg">
        {c.sub}
      </p>

      <!-- ===== CTA buttons (the garage lookup now lives at step 1 of the wizard) ===== -->
      <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={L('/get-started', lang)}
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-600 px-7 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/30 hover:bg-brand-700 transition sm:w-auto"
        >
          {c.getStarted}
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
        </a>
        <a
          href={L('/how-it-works', lang)}
          class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-ink-300 bg-white px-7 py-3.5 text-base font-semibold text-ink-800 hover:bg-ink-50 transition sm:w-auto"
        >
          {c.seeHow}
        </a>
      </div>

      <p class="mt-5 text-sm text-ink-500">
        {c.billing}
      </p>

      <p class="mt-3 text-sm text-ink-600">
        {c.demoPrompt}{' '}
        <button type="button" data-lead-cta="website-hero-demo" data-lead-tier={c.demoTier} class="font-semibold text-brand-700 underline underline-offset-2 hover:text-brand-800">
          {c.demoCta}
        </button>
      </p>

      <!-- Avatar / rating row — hidden on mobile to reduce hero clutter -->
      <div class="mt-7 hidden items-center justify-center gap-4 sm:flex">
        <div class="flex -space-x-2">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-600 ring-2 ring-white text-xs font-semibold text-white">EA</span>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-emerald-600 ring-2 ring-white text-xs font-semibold text-white">EL</span>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-amber-600 ring-2 ring-white text-xs font-semibold text-white">IO</span>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-sky-600 ring-2 ring-white text-xs font-semibold text-white">RP</span>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-rose-600 ring-2 ring-white text-xs font-semibold text-white">SJ</span>
        </div>
        <div class="text-left">
          <div class="flex items-center gap-0.5 text-amber-500">
            {Array.from({ length: 5 }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/></svg>
            ))}
          </div>
          <p class="text-xs text-ink-500">{c.trusted}</p>
        </div>
      </div>
    </div>
  </div>
</section>
