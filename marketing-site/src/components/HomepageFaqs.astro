---
// Top 4 questions from /faqs surfaced on the homepage just before the Signup
// CTA — gives mobile visitors quick objection-handling without having to
// navigate to the dedicated FAQ page. Verbatim from /faqs.astro so when one
// answer changes there, mirror it here.

const items = [
  {
    q: 'Do I need to change my phone number?',
    a: "No. You keep your existing number. We provision a ReceptionMate number, and you set call forwarding on your existing landline or mobile: if a call rings 5–7 times without anyone picking up, it forwards to ReceptionMate. Out of hours, every call forwards automatically. Your team still answers first when they can.",
  },
  {
    q: 'How long does setup take?',
    a: "Assist is live in minutes. Automate and Connect take 3–5 days because we configure your integrations (Garage Hive, Tyresoft, WhatsApp Business etc.) before going live.",
  },
  {
    q: 'Can ReceptionMate actually book a job, or does it just take a message?',
    a: "It books the job live during the call. It reads your diary, offers free slots, reserves the chosen one in real time, and confirms by SMS before the call ends.",
  },
  {
    q: 'Is there a contract?',
    a: "No long-term contract. You can stop using ReceptionMate at any time — just disable the call-forwarding rule.",
  },
];
---

<section class="bg-white py-16 sm:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">Frequently asked</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        The questions garage owners ask first.
      </h2>
    </div>

    <div class="mt-10 space-y-3">
      {items.map((item) => (
        <details class="group rounded-2xl border border-ink-200 bg-white p-5 transition open:shadow-md sm:p-6">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-left">
            <h3 class="text-base font-semibold text-ink-900 sm:text-lg">{item.q}</h3>
            <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-700 transition group-open:rotate-45" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"/></svg>
            </span>
          </summary>
          <p class="mt-3 text-base leading-relaxed text-ink-700">{item.a}</p>
        </details>
      ))}
    </div>

    <p class="mt-6 text-center text-sm text-ink-500">
      More questions covered on the <a href="/faqs" class="font-medium text-brand-700 underline hover:text-brand-800">full FAQ page</a>.
    </p>
  </div>
</section>
