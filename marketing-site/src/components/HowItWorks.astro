                <div id="how-progress" class="h-full w-0 bg-brand-600 transition-[width]"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root      = document.getElementById('how-root');
    if (!root) return;
    const steps     = Array.from(root.querySelectorAll('.how-step'));
    const screens   = Array.from(root.querySelectorAll('.how-screen'));
    const progress  = document.getElementById('how-progress');
    const urlText   = document.getElementById('how-url-text');
    const DURATION  = 6000;

    // Mobile: clone each desktop screen into its matching mobile slot so the
    // visuals match exactly with no duplicated markup. Mobile slots have
    // data-mobile-mockup="N" matching data-screen="N" on the desktop screens.
    const mobileClones = [];
    screens.forEach((screen) => {
      const idx = screen.getAttribute('data-screen');
      const slot = document.querySelector(`[data-mobile-mockup="${idx}"]`);
      if (!slot) return;
      const clone = screen.cloneNode(true);
      clone.classList.remove('absolute', 'inset-0', 'opacity-0', 'transition-opacity', 'duration-500');
      clone.classList.add('relative', 'h-full', 'w-full');
      slot.appendChild(clone);
      mobileClones.push({ idx, clone, slot });
    });

    // Mobile animations: typewriter on step 0's garage-name input, counter
    // on step 3's captured revenue and confirmed bookings. Both triggered
    // when the mockup slot scrolls into view; replay if the user scrolls
    // back up so it feels alive.
    const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

    const runTypewriter = (el) => {
      const text = el.getAttribute('data-typewriter') || '';
      el.textContent = '';
      let i = 0;
      const tick = () => {
        if (i > text.length) return;
        el.textContent = text.slice(0, i);
        i += 1;
        if (i <= text.length) setTimeout(tick, 70 + Math.random() * 40);
      };
      setTimeout(tick, 400);
    };

    const runCounter = (el) => {
      const target = parseInt(el.getAttribute('data-count-to') || '0', 10);
      const prefix = el.getAttribute('data-count-prefix') || '';
      const useComma = el.getAttribute('data-count-comma') === '1';
      const duration = 1200;
      const start = performance.now();
      const step = (now) => {
        const elapsed = now - start;
        const t = Math.min(1, elapsed / duration);
        const value = Math.round(target * easeOutCubic(t));
        const formatted = useComma ? value.toLocaleString('en-GB') : String(value);
        el.textContent = `${prefix}${formatted}`;
        if (t < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    };

    if ('IntersectionObserver' in window) {
      mobileClones.forEach(({ slot }) => {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              slot.querySelectorAll('[data-typewriter]').forEach(runTypewriter);
              slot.querySelectorAll('[data-count-to]').forEach(runCounter);
              io.unobserve(slot); // once per page view; comment out to replay
            });
          },
          { threshold: 0.4 },
        );
        io.observe(slot);
      });
    }

    let current = 0;
    let timer   = null;
    let userInteracted = false;

    function setStep(i) {
      current = i;
      steps.forEach((s, idx) => {
        if (idx === i) s.setAttribute('aria-current', 'step'); else s.removeAttribute('aria-current');
      });
      screens.forEach((s, idx) => {
        s.style.opacity = idx === i ? '1' : '0';
        s.style.pointerEvents = idx === i ? 'auto' : 'none';
      });
      // Update the browser URL bar
      const active = screens[i];
      if (urlText && active) urlText.textContent = active.dataset.url || 'receptionmate.co.uk';
      resetProgress();
    }

    function resetProgress() {
      if (!progress) return;
      progress.style.transitionDuration = '0ms';
      progress.style.width = '0%';
      void progress.offsetWidth;
      progress.style.transitionDuration = DURATION + 'ms';
      progress.style.width = '100%';
    }

    function scheduleNext() {
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => {
        if (userInteracted) return;
        setStep((current + 1) % steps.length);
        scheduleNext();
      }, DURATION);
    }

    steps.forEach((btn) => {
      btn.addEventListener('click', () => {
        userInteracted = true;
        if (timer) clearTimeout(timer);
        setStep(parseInt(btn.dataset.step, 10));
      });
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !userInteracted) {
          setStep(current);
          scheduleNext();
        } else if (timer) {
          clearTimeout(timer);
        }
      });
    }, { threshold: 0.35 });
    io.observe(root);

    setStep(0);
  })();
</script>
