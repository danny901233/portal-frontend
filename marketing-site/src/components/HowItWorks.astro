    bookings: [
      { name: 'J. Davies', svc: 'Contrôle technique', when: 'Mar. 8:00',  price: '£54.85' },
      { name: 'S. Patel',  svc: 'Entretien intermédiaire', when: 'Mer. 10:30', price: '£225.00' },
      { name: 'R. Khan',   svc: 'Liquide de frein', when: 'Jeu. 9:15',  price: '£50.00' },
