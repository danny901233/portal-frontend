<script is:inline>
  (() => {
    const root      = document.getElementById('how-root');
    if (!root) return;
    const steps     = Array.from(root.querySelectorAll('.how-step'));
    const screens   = Array.from(root.querySelectorAll('.how-screen'));
    const progress  = document.getElementById('how-progress');
    const urlText   = document.getElementById('how-url-text');
    const DURATION  = 6000;

    // Mobile: clone each desktop screen into its matching mobile slot so the
    // visuals match exactly with no duplicated markup. Mobile slots have
    // data-mobile-mockup="N" matching data-screen="N" on the desktop screens.
    screens.forEach((screen) => {
      const idx = screen.getAttribute('data-screen');
      const slot = document.querySelector(`[data-mobile-mockup="${idx}"]`);
      if (!slot) return;
      const clone = screen.cloneNode(true);
      // Strip the absolute-overlay positioning + opacity-swap classes so the
      // clone renders normally in flow inside the mobile slot, always visible.
      clone.classList.remove('absolute', 'inset-0', 'opacity-0', 'transition-opacity', 'duration-500');
      clone.classList.add('relative', 'h-full', 'w-full');
      slot.appendChild(clone);
    });

    let current = 0;
    let timer   = null;
    let userInteracted = false;

    function setStep(i) {
      current = i;
      steps.forEach((s, idx) => {
        if (idx === i) s.setAttribute('aria-current', 'step'); else s.removeAttribute('aria-current');
      });
      screens.forEach((s, idx) => {
        s.style.opacity = idx === i ? '1' : '0';
        s.style.pointerEvents = idx === i ? 'auto' : 'none';
      });
      // Update the browser URL bar
      const active = screens[i];
      if (urlText && active) urlText.textContent = active.dataset.url || 'receptionmate.co.uk';
      resetProgress();
    }

    function resetProgress() {
      if (!progress) return;
      progress.style.transitionDuration = '0ms';
      progress.style.width = '0%';
      void progress.offsetWidth;
      progress.style.transitionDuration = DURATION + 'ms';
      progress.style.width = '100%';
    }

    function scheduleNext() {
      if (timer) clearTimeout(timer);
      timer = setTimeout(() => {
        if (userInteracted) return;
        setStep((current + 1) % steps.length);
        scheduleNext();
      }, DURATION);
    }

    steps.forEach((btn) => {
      btn.addEventListener('click', () => {
        userInteracted = true;
        if (timer) clearTimeout(timer);
        setStep(parseInt(btn.dataset.step, 10));
      });
    });

    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting && !userInteracted) {
          setStep(current);
          scheduleNext();
        } else if (timer) {
          clearTimeout(timer);
        }
      });
    }, { threshold: 0.35 });
    io.observe(root);

    setStep(0);
  })();
</script>
