    s2ProviderValue: 'BT Business · Ligne fixe',
    s2ForwardHeading: 'Transférer si occupé ou sans réponse',
    s2Step1a: 'Depuis le téléphone du garage, composez',
    s2Step2: 'Attendez la tonalité de confirmation.',
