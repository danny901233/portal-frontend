                            <p class="mt-0.5 text-[8.5px] font-semibold text-white leading-none">0333 370 1610</p>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                  <div class="flex flex-1 flex-col">
                    <div class="flex items-center justify-between border-b border-slate-200 bg-white px-4 py-2">
                      <div class="flex items-center gap-2 rounded-md border border-slate-200 bg-white px-2 py-1 text-[9.5px] text-slate-900">
                        <span>Acme Auto Centre</span>
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-2.5 w-2.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                      </div>
                      <div class="text-right">
                        <p class="text-[7.5px] font-medium uppercase tracking-[0.2em] text-slate-500">{c.signedIn}</p>
                        <p class="text-[9.5px] font-semibold text-slate-900">dan@acmeauto.co.uk</p>
                      </div>
                    </div>
                    <div class="flex-1 px-4 py-3">
                      <h4 class="text-sm font-bold text-slate-900">{c.s3Title}</h4>
                      <p class="text-[9px] text-slate-500">{c.s3Sub}</p>

                      <!-- Captured revenue hero band (mirrors real dashboard) -->
                      <div class="relative mt-2 overflow-hidden rounded-xl bg-brand-600 px-3 py-3 shadow-md shadow-brand-600/20">
                        <div class="absolute -top-8 -right-8 h-16 w-16 rounded-full bg-brand-400/30 blur-2xl"></div>
                        <div class="absolute -bottom-8 -left-8 h-16 w-16 rounded-full bg-fuchsia-500/20 blur-2xl"></div>
                        <div class="relative grid grid-cols-2 gap-3">
                          <div>
                            <p class="text-[7.5px] font-semibold uppercase tracking-[0.25em] text-brand-100">{c.s3CapturedRevenue}</p>
                            <p class="mt-0.5 text-lg font-semibold text-white" data-count-to="3847" data-count-prefix="£" data-count-comma="1">£3,847</p>
                            <p class="mt-0.5 text-[8.5px] text-brand-100">{c.s3WeeksBookings}</p>
                          </div>
                          <div class="rounded-lg border border-white/15 bg-white/10 px-2 py-1.5 backdrop-blur-sm">
                            <p class="text-[7.5px] font-semibold uppercase tracking-[0.2em] text-brand-100">{c.s3ConfirmedBookings}</p>
                            <p class="mt-0.5 text-lg font-semibold text-white" data-count-to="23">23</p>
