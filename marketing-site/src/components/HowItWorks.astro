                          <p class="mt-0.5 text-sm font-semibold text-slate-900">142</p>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white p-1.5">
                          <p class="text-[7.5px] font-medium uppercase tracking-wide text-slate-500">{c.s3KpiTimeSaved}</p>
                          <p class="mt-0.5 text-sm font-semibold text-slate-900">3h 47m</p>
                        </div>
                        <div class="rounded-lg border border-slate-200 bg-white p-1.5">
                          <p class="text-[7.5px] font-medium uppercase tracking-wide text-slate-500">{c.s3KpiTopTag}</p>
                          <p class="mt-0.5 text-sm font-semibold text-slate-900">{c.s3TopTag}</p>
