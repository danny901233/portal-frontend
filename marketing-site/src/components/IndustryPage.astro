---
// Shared template for the /for/[slug] (EN) and /fr/for/[slug] (FR) industry
// landing pages. Both routes have their own getStaticPaths over INDUSTRIES and
// render this component with the matched industry as a prop — the language is
// derived from the URL, so the same component serves both locales.
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyUs from '../components/WhyUs.astro';
import { getLang, L } from '../i18n/ui';
import type { Industry } from '../data/industries';

const { industry } = Astro.props as { industry: Industry };
const lang = getLang(Astro.url);

// Locale copy pulled straight from the data file.
const displayName = lang === 'fr' ? industry.displayNameFr : industry.displayName;
const context = lang === 'fr' ? industry.contextFr : industry.context;
const pain = lang === 'fr' ? industry.painFr : industry.pain;
const highlights = lang === 'fr' ? industry.highlightsFr : industry.highlights;

// Static template strings.
const c = {
  en: {
    seoTitle: `AI receptionist for ${industry.name} — ReceptionMate`,
    seoDescription: `ReceptionMate is the AI receptionist built for ${displayName}. Answers every call, books every job, integrates with the UK garage stack.`,
    eyebrow: `For ${displayName}`,
    h1a: 'The AI receptionist',
    h1b: `built for ${displayName}.`,
    getStarted: 'Get started',
    caseStudies: 'See case studies',
    highlightsEyebrow: `What ReceptionMate does for ${displayName}`,
    highlightsHeading: 'Three things that change on day one.',
    ctaHeading: 'See ReceptionMate handle your calls.',
    ctaBody:
      "No contract. You keep your existing number — we set up call forwarding so the AI catches the calls your team can't get to.",
  },
  fr: {
    seoTitle: `Réceptionniste IA pour ${industry.name} — ReceptionMate`,
    seoDescription: `ReceptionMate est la réceptionniste IA conçue pour les ${displayName}. Elle répond à chaque appel, réserve chaque intervention et s’intègre à vos outils de garage.`,
    eyebrow: `Pour les ${displayName}`,
    h1a: 'La réceptionniste IA',
    h1b: `conçue pour les ${displayName}.`,
    getStarted: 'Commencer',
    caseStudies: 'Voir les études de cas',
    highlightsEyebrow: `Ce que ReceptionMate fait pour les ${displayName}`,
    highlightsHeading: 'Trois choses qui changent dès le premier jour.',
    ctaHeading: 'Voyez ReceptionMate gérer vos appels.',
    ctaBody:
      'Sans engagement. Vous gardez votre numéro actuel — nous mettons en place le renvoi d’appel pour que l’IA capte les appels que votre équipe ne peut pas prendre.',
  },
}[lang];
---

<BaseLayout title={c.seoTitle} description={c.seoDescription}>

  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 h-96 w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-5xl px-4 pt-16 pb-12 sm:px-6 lg:px-8 lg:pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">
        {c.eyebrow}
      </p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        {c.h1a}<br/>
        <span class="text-brand-600">{c.h1b}</span>
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-ink-700">{context}</p>
      <p class="mt-4 max-w-3xl text-base leading-relaxed text-ink-600">{pain}</p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={L('/get-started', lang)} class="inline-flex items-center justify-center rounded-md bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition">
          {c.getStarted}
        </a>
        <a href={L('/case-studies', lang)} class="inline-flex items-center justify-center rounded-md border border-ink-300 px-5 py-3 text-sm font-semibold text-ink-700 hover:border-ink-400 transition">
          {c.caseStudies}
        </a>
      </div>
    </div>
  </section>

  <!-- Industry highlights -->
  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.highlightsEyebrow}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
          {c.highlightsHeading}
        </h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {highlights.map((h) => (
          <div class="rounded-2xl border border-ink-200 bg-white p-6">
            <h3 class="text-lg font-semibold text-ink-900">{h.title}</h3>
            <p class="mt-2 text-base leading-relaxed text-ink-700">{h.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Reuse the comparison table — the differentiation message is the same. -->
  <WhyUs />

  <!-- CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-brand-600 p-10 text-center sm:p-14">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {c.ctaHeading}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
          {c.ctaBody}
        </p>
        <div class="mt-8">
          <a
            href={L('/get-started', lang)}
            class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow-sm hover:bg-brand-50 transition"
          >
            {c.getStarted}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
