---
// Global lead-capture modal. Any element on the site with the attributes
//   data-lead-cta="<source>"   e.g. "website-tier-connect"
//   data-lead-tier="<label>"   e.g. "Connect" (used in the modal title)
// will open this modal when clicked. The form POSTs to /api/public/lead
// which creates a HighLevel contact + emails the team.
//
// Mounted once in BaseLayout so every page picks it up automatically.
import { getLang } from '../i18n/ui';
const lang = getLang(Astro.url);
const LEAD_ENDPOINT = import.meta.env.PUBLIC_LEAD_ENDPOINT || 'https://portal.receptionmate.co.uk/api/public/lead';
const c = {
  en: {
    close: 'Close',
    titleLead: 'Talk to us about',
    intro: 'A few quick details and someone from the team will be in touch.',
    nameLabel: 'Your name',
    namePlaceholder: 'Jane Smith',
    companyLabel: 'Garage or company name',
    companyPlaceholder: 'Acme Auto Centre',
    emailLabel: 'Email address',
    emailPlaceholder: 'you@yourgarage.co.uk',
    phoneLabel: 'Phone number',
    phonePlaceholder: '07700 000000',
    sendIt: 'Send it',
    sending: 'Sending…',
    noCommitment: "No commitment · we'll be in touch within one working day",
    successTitle: 'Thanks — we’ve got your details.',
    successBody: 'Someone from the team will be in touch within one working day.',
    errorMsg: "Couldn't send that — try again, or email hello@receptionmate.co.uk.",
  },
  fr: {
    close: 'Fermer',
    titleLead: 'Parlons de',
    intro: 'Quelques informations rapides et un membre de l’équipe vous recontactera.',
    nameLabel: 'Votre nom',
    namePlaceholder: 'Jean Dupont',
    companyLabel: 'Nom du garage ou de l’entreprise',
    companyPlaceholder: 'Acme Auto Centre',
    emailLabel: 'Adresse e-mail',
    emailPlaceholder: 'vous@votregarage.fr',
    phoneLabel: 'Numéro de téléphone',
    phonePlaceholder: '06 12 34 56 78',
    sendIt: 'Envoyer',
    sending: 'Envoi…',
    noCommitment: "Sans engagement · nous vous recontactons sous un jour ouvré",
    successTitle: 'Merci — nous avons bien reçu vos coordonnées.',
    successBody: 'Un membre de l’équipe vous recontactera sous un jour ouvré.',
    errorMsg: "Impossible d'envoyer — réessayez, ou écrivez à hello@receptionmate.co.uk.",
  },
}[lang];
---

<div
  id="lead-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-ink-900/70 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lead-modal-title"
>
  <div class="relative w-full max-w-md overflow-hidden rounded-2xl bg-white shadow-2xl ring-1 ring-ink-200/50">
    <button
      type="button"
      id="lead-modal-close"
      aria-label={c.close}
      class="absolute right-3 top-3 z-10 inline-flex h-9 w-9 items-center justify-center rounded-full text-white/80 hover:bg-white/10 hover:text-white"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <!-- Brand band -->
    <div class="relative overflow-hidden bg-gradient-to-br from-brand-600 to-brand-700 px-6 py-6 text-white">
      <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-white/10 blur-2xl" aria-hidden="true"></div>
      <h2 id="lead-modal-title" class="text-xl font-bold leading-tight">
        {c.titleLead} <span id="lead-modal-tier">ReceptionMate</span>
      </h2>
      <p class="mt-1.5 text-sm text-brand-100">{c.intro}</p>
    </div>

    <form id="lead-modal-form" class="space-y-4 p-6">
      <input type="hidden" name="source" id="lead-modal-source" value="" />

      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-800" for="lead-modal-name">{c.nameLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <input
            type="text"
            id="lead-modal-name"
            name="name"
            required
            minlength="2"
            autocomplete="name"
            placeholder={c.namePlaceholder}
            class="lead-input"
          />
        </div>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-800" for="lead-modal-company">{c.companyLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8l7-4 7 4v13M9 9h.01M13 9h.01M9 13h.01M13 13h.01M9 17h.01M13 17h.01"/></svg>
          <input
            type="text"
            id="lead-modal-company"
            name="companyName"
            required
            minlength="2"
            autocomplete="organization"
            placeholder={c.companyPlaceholder}
            class="lead-input"
          />
        </div>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-800" for="lead-modal-email">{c.emailLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l8.5 5.5a2 2 0 002 0L22 8M4 5h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V7a2 2 0 012-2z"/></svg>
          <input
            type="email"
            id="lead-modal-email"
            name="email"
            required
            autocomplete="email"
            placeholder={c.emailPlaceholder}
            class="lead-input"
          />
        </div>
      </div>

      <div>
        <label class="mb-1.5 block text-sm font-medium text-ink-800" for="lead-modal-phone">{c.phoneLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <input
            type="tel"
            id="lead-modal-phone"
            name="phone"
            required
            autocomplete="tel"
            placeholder={c.phonePlaceholder}
            class="lead-input"
          />
        </div>
      </div>

      <div id="lead-modal-error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-xs text-rose-700 ring-1 ring-rose-200"></div>

      <button
        type="submit"
        class="group mt-2 inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-600/25 transition hover:bg-brand-700 hover:shadow-brand-600/40 disabled:opacity-50"
      >
        <span data-state="idle">{c.sendIt}</span>
        <span data-state="loading" class="hidden inline-flex items-center gap-2">
          <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-30"/>
            <path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
          {c.sending}
        </span>
        <svg data-state="idle" class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
      </button>

      <p class="pt-1 text-center text-xs text-ink-400">{c.noCommitment}</p>
    </form>

    <div id="lead-modal-success" class="hidden px-6 py-8 text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
        <svg class="h-6 w-6 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <p class="mt-4 text-base font-semibold text-ink-900">{c.successTitle}</p>
      <p class="mt-2 text-sm text-ink-600">{c.successBody}</p>
      <button
        type="button"
        id="lead-modal-success-close"
        class="mt-5 inline-flex items-center justify-center rounded-lg border border-ink-300 bg-white px-4 py-2 text-sm font-medium text-ink-700 hover:bg-ink-50"
      >
        {c.close}
      </button>
    </div>
  </div>
</div>

<style>
  .lead-input-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }
  .lead-input-icon {
    position: absolute;
    left: 0.875rem;
    height: 1.125rem;
    width: 1.125rem;
    color: #94a3b8; /* ink-400 */
    pointer-events: none;
    transition: color 0.15s ease;
  }
  .lead-input {
    width: 100%;
    border-radius: 0.75rem;
    border: 1px solid #cbd5e1; /* ink-300 */
    background: #fff;
    padding: 0.75rem 0.875rem 0.75rem 2.5rem;
    font-size: 0.95rem;
    color: #0f172a; /* ink-900 */
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .lead-input::placeholder {
    color: #94a3b8;
  }
  .lead-input:hover {
    border-color: #94a3b8;
  }
  .lead-input:focus {
    outline: none;
    border-color: #3426cf; /* brand-600 */
    box-shadow: 0 0 0 4px rgba(52, 38, 207, 0.12);
    background: #fff;
  }
  .lead-input:focus + .lead-input-icon,
  .lead-input-wrap:focus-within .lead-input-icon {
    color: #3426cf;
  }
  .lead-input:invalid:not(:placeholder-shown) {
    border-color: #fda4af;
    box-shadow: 0 0 0 4px rgba(244, 63, 94, 0.08);
  }
</style>

<script define:vars={{ LEAD_ENDPOINT, ERROR_MSG: c.errorMsg }}>
  const modal     = document.getElementById('lead-modal');
  const form      = document.getElementById('lead-modal-form');
  const closeBtn  = document.getElementById('lead-modal-close');
  const successEl = document.getElementById('lead-modal-success');
  const successCloseBtn = document.getElementById('lead-modal-success-close');
  const errorEl   = document.getElementById('lead-modal-error');
  const sourceInput = document.getElementById('lead-modal-source');
  const tierLabelEl = document.getElementById('lead-modal-tier');

  if (modal && form) {
    const open = (source, tier) => {
      sourceInput.value = source || 'website';
      tierLabelEl.textContent = tier || 'ReceptionMate';
      errorEl.classList.add('hidden');
      successEl.classList.add('hidden');
      form.classList.remove('hidden');
      // Reset form between opens but keep the source/tier we just set
      form.querySelectorAll('input[type="text"], input[type="email"], input[type="tel"]').forEach((el) => { el.value = ''; });
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('lead-modal-name')?.focus(), 50);
    };

    const close = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    };

    // Wire up every CTA on the page
    document.querySelectorAll('[data-lead-cta]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const source = el.getAttribute('data-lead-cta') || 'website';
        const tier = el.getAttribute('data-lead-tier') || '';
        open(source, tier);
      });
    });

    closeBtn?.addEventListener('click', close);
    successCloseBtn?.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const btn = form.querySelector('button[type="submit"]');
      const idleEls = form.querySelectorAll('[data-state="idle"]');
      const loadEl = form.querySelector('[data-state="loading"]');
      btn.disabled = true;
      idleEls.forEach((el) => el.classList.add('hidden'));
      loadEl.classList.remove('hidden');

      try {
        const payload = Object.fromEntries(new FormData(form));
        const res = await fetch(LEAD_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form.classList.add('hidden');
          successEl.classList.remove('hidden');
        } else {
          throw new Error('HTTP ' + res.status);
        }
      } catch (err) {
        errorEl.textContent = ERROR_MSG;
        errorEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        idleEls.forEach((el) => el.classList.remove('hidden'));
        loadEl.classList.add('hidden');
      }
    });
  }
</script>
