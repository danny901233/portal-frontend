---
// Global lead-capture modal. Any element on the site with the attributes
//   data-lead-cta="<source>"   e.g. "website-tier-connect"
//   data-lead-tier="<label>"   e.g. "Connect" (used in the modal title)
// will open this modal when clicked. The form POSTs to /api/public/lead
// which upserts a HighLevel contact, creates an opportunity in the
// "Onboarding Newest" pipeline, and emails the team.
//
// Mounted once in BaseLayout so every page picks it up automatically.
import { getLang } from '../i18n/ui';
const lang = getLang(Astro.url);
const LEAD_ENDPOINT = import.meta.env.PUBLIC_LEAD_ENDPOINT || 'https://portal.receptionmate.co.uk/api/public/lead';
const LOGO = 'https://storage.googleapis.com/msgsndr/2UadumwHCXxeU9yxBIRC/media/65cf28be6e4392e608cca8a9.png';
const c = {
  en: {
    close: 'Close',
    titleLead: 'Talk to us about',
    intro: 'A few quick details and someone from the team will be in touch — usually the same day.',
    nameLabel: 'Your name',
    namePlaceholder: 'Jane Smith',
    companyLabel: 'Garage or company name',
    companyPlaceholder: 'Acme Auto Centre',
    emailLabel: 'Email address',
    emailPlaceholder: 'you@yourgarage.co.uk',
    phoneLabel: 'Phone number',
    phonePlaceholder: '07700 000000',
    sendIt: 'Send it',
    sending: 'Sending…',
    noCommitment: "No commitment · we'll be in touch within one working day",
    successTitle: 'Thanks — we’ve got your details.',
    successBody: 'Someone from the team will be in touch within one working day.',
    errorMsg: "Couldn't send that — try again, or email hello@receptionmate.co.uk.",
  },
  fr: {
    close: 'Fermer',
    titleLead: 'Parlons de',
    intro: 'Quelques informations rapides et un membre de l’équipe vous recontactera — souvent le jour même.',
    nameLabel: 'Votre nom',
    namePlaceholder: 'Jean Dupont',
    companyLabel: 'Nom du garage ou de l’entreprise',
    companyPlaceholder: 'Acme Auto Centre',
    emailLabel: 'Adresse e-mail',
    emailPlaceholder: 'vous@votregarage.fr',
    phoneLabel: 'Numéro de téléphone',
    phonePlaceholder: '06 12 34 56 78',
    sendIt: 'Envoyer',
    sending: 'Envoi…',
    noCommitment: "Sans engagement · nous vous recontactons sous un jour ouvré",
    successTitle: 'Merci — nous avons bien reçu vos coordonnées.',
    successBody: 'Un membre de l’équipe vous recontactera sous un jour ouvré.',
    errorMsg: "Impossible d'envoyer — réessayez, ou écrivez à hello@receptionmate.co.uk.",
  },
}[lang];
---

<div
  id="lead-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-ink-900/70 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-labelledby="lead-modal-title"
>
  <div class="lead-card relative w-full max-w-md overflow-hidden rounded-3xl bg-white shadow-2xl ring-1 ring-ink-900/5">
    <button
      type="button"
      id="lead-modal-close"
      aria-label={c.close}
      class="absolute right-4 top-4 z-10 inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/15 text-white transition hover:bg-white/25"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>

    <!-- Brand band -->
    <div class="relative overflow-hidden bg-gradient-to-br from-brand-600 via-brand-600 to-brand-800 px-7 pb-7 pt-6 text-white">
      <div class="absolute -right-10 -top-12 h-40 w-40 rounded-full bg-white/10 blur-2xl" aria-hidden="true"></div>
      <div class="absolute -bottom-16 -left-10 h-40 w-40 rounded-full bg-brand-400/20 blur-2xl" aria-hidden="true"></div>
      <img src={LOGO} alt="ReceptionMate" class="relative h-9 w-auto" />
      <h2 id="lead-modal-title" class="relative mt-4 text-2xl font-bold leading-tight tracking-tight">
        {c.titleLead} <span id="lead-modal-tier">ReceptionMate</span>
      </h2>
      <p class="relative mt-2 text-sm leading-relaxed text-brand-100">{c.intro}</p>
    </div>

    <form id="lead-modal-form" class="space-y-3.5 p-7">
      <input type="hidden" name="source" id="lead-modal-source" value="" />

      <div>
        <label class="lead-label" for="lead-modal-name">{c.nameLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          <input type="text" id="lead-modal-name" name="name" required minlength="2" autocomplete="name" placeholder={c.namePlaceholder} class="lead-input" />
        </div>
      </div>

      <div>
        <label class="lead-label" for="lead-modal-company">{c.companyLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V8l7-4 7 4v13M9 9h.01M13 9h.01M9 13h.01M13 13h.01M9 17h.01M13 17h.01"/></svg>
          <input type="text" id="lead-modal-company" name="companyName" required minlength="2" autocomplete="organization" placeholder={c.companyPlaceholder} class="lead-input" />
        </div>
      </div>

      <div>
        <label class="lead-label" for="lead-modal-email">{c.emailLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l8.5 5.5a2 2 0 002 0L22 8M4 5h16a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V7a2 2 0 012-2z"/></svg>
          <input type="email" id="lead-modal-email" name="email" required autocomplete="email" placeholder={c.emailPlaceholder} class="lead-input" />
        </div>
      </div>

      <div>
        <label class="lead-label" for="lead-modal-phone">{c.phoneLabel}</label>
        <div class="lead-input-wrap">
          <svg class="lead-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <input type="tel" id="lead-modal-phone" name="phone" required autocomplete="tel" placeholder={c.phonePlaceholder} class="lead-input" />
        </div>
      </div>

      <div id="lead-modal-error" class="hidden rounded-lg bg-rose-50 px-3 py-2 text-xs text-rose-700 ring-1 ring-rose-200"></div>

      <button type="submit" id="lead-modal-submit" class="lead-submit group mt-1.5 w-full rounded-xl bg-gradient-to-r from-brand-600 to-brand-500 px-4 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand-600/30 transition hover:shadow-brand-600/50 disabled:cursor-not-allowed disabled:opacity-70">
        <span class="seg-idle">
          {c.sendIt}
          <svg class="h-4 w-4 transition group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
        </span>
        <span class="seg-loading">
          <svg class="h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" class="opacity-30"/>
            <path d="M4 12a8 8 0 018-8" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
          </svg>
          {c.sending}
        </span>
      </button>

      <p class="flex items-center justify-center gap-1.5 pt-0.5 text-center text-xs text-ink-400">
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 018 0v4"/></svg>
        {c.noCommitment}
      </p>
    </form>

    <div id="lead-modal-success" class="hidden px-7 py-10 text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-emerald-100 ring-8 ring-emerald-50">
        <svg class="h-7 w-7 text-emerald-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <p class="mt-5 text-lg font-bold text-ink-900">{c.successTitle}</p>
      <p class="mt-2 text-sm leading-relaxed text-ink-600">{c.successBody}</p>
      <button type="button" id="lead-modal-success-close" class="mt-6 inline-flex items-center justify-center rounded-xl border border-ink-300 bg-white px-5 py-2.5 text-sm font-semibold text-ink-700 transition hover:bg-ink-50">
        {c.close}
      </button>
    </div>
  </div>
</div>

<style>
  .lead-card { animation: lead-pop 0.28s cubic-bezier(0.2, 0.9, 0.3, 1.2); }
  @keyframes lead-pop { from { opacity: 0; transform: translateY(12px) scale(0.97); } to { opacity: 1; transform: none; } }

  .lead-label { margin-bottom: 0.375rem; display: block; font-size: 0.8125rem; font-weight: 600; color: #334155; }

  .lead-input-wrap { position: relative; display: flex; align-items: center; }
  .lead-input-icon {
    position: absolute; left: 1rem; height: 1.125rem; width: 1.125rem;
    color: #94a3b8; pointer-events: none; transition: color 0.15s ease;
  }
  .lead-input {
    width: 100%; border-radius: 0.875rem; border: 1.5px solid #e2e8f0; background: #f8fafc;
    padding: 0.8rem 1rem 0.8rem 2.75rem; font-size: 0.95rem; color: #0f172a;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }
  .lead-input::placeholder { color: #94a3b8; }
  .lead-input:hover { border-color: #cbd5e1; background: #fff; }
  .lead-input:focus {
    outline: none; background: #fff; border-color: #3426cf;
    box-shadow: 0 0 0 4px rgba(52, 38, 207, 0.12);
  }
  .lead-input-wrap:focus-within .lead-input-icon { color: #3426cf; }
  .lead-input:invalid:not(:placeholder-shown) {
    border-color: #fda4af; box-shadow: 0 0 0 4px rgba(244, 63, 94, 0.08);
  }

  /* Submit button idle/loading segments — driven by an .is-loading class on the
     button so there's no Tailwind display conflict (the old markup showed both). */
  .lead-submit .seg-idle,
  .lead-submit .seg-loading { align-items: center; justify-content: center; gap: 0.5rem; }
  .lead-submit .seg-idle { display: inline-flex; }
  .lead-submit .seg-loading { display: none; }
  .lead-submit.is-loading .seg-idle { display: none; }
  .lead-submit.is-loading .seg-loading { display: inline-flex; }
</style>

<script define:vars={{ LEAD_ENDPOINT, ERROR_MSG: c.errorMsg }}>
  const modal     = document.getElementById('lead-modal');
  const form      = document.getElementById('lead-modal-form');
  const closeBtn  = document.getElementById('lead-modal-close');
  const successEl = document.getElementById('lead-modal-success');
  const successCloseBtn = document.getElementById('lead-modal-success-close');
  const errorEl   = document.getElementById('lead-modal-error');
  const sourceInput = document.getElementById('lead-modal-source');
  const tierLabelEl = document.getElementById('lead-modal-tier');

  if (modal && form) {
    const open = (source, tier) => {
      sourceInput.value = source || 'website';
      tierLabelEl.textContent = tier || 'ReceptionMate';
      errorEl.classList.add('hidden');
      successEl.classList.add('hidden');
      form.classList.remove('hidden');
      form.querySelectorAll('input[type="text"], input[type="email"], input[type="tel"]').forEach((el) => { el.value = ''; });
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      setTimeout(() => document.getElementById('lead-modal-name')?.focus(), 50);
    };

    const close = () => {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    };

    document.querySelectorAll('[data-lead-cta]').forEach((el) => {
      el.addEventListener('click', (e) => {
        e.preventDefault();
        const source = el.getAttribute('data-lead-cta') || 'website';
        const tier = el.getAttribute('data-lead-tier') || '';
        open(source, tier);
      });
    });

    closeBtn?.addEventListener('click', close);
    successCloseBtn?.addEventListener('click', close);
    modal.addEventListener('click', (e) => { if (e.target === modal) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');
      const btn = form.querySelector('#lead-modal-submit');
      btn.disabled = true;
      btn.classList.add('is-loading');

      try {
        const payload = Object.fromEntries(new FormData(form));
        const res = await fetch(LEAD_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const data = await res.json().catch(() => ({}));
        if (res.ok && data.ok) {
          form.classList.add('hidden');
          successEl.classList.remove('hidden');
        } else {
          throw new Error('HTTP ' + res.status);
        }
      } catch (err) {
        errorEl.textContent = ERROR_MSG;
        errorEl.classList.remove('hidden');
      } finally {
        btn.disabled = false;
        btn.classList.remove('is-loading');
      }
    });
  }
</script>
