---
// Closing CTA — main signup is in the hero. This is a "ready when you are" prompt
// that scrolls back to the hero form rather than duplicating it.
import { getLang, L } from '../i18n/ui';
const lang = getLang(Astro.url);
const c = {
  en: {
    eyebrow: 'Ready when you are',
    h2: 'See Leah answer your phone.',
    sub: 'Drop your business name and email — Assist goes live in minutes.',
    getStarted: 'Get started',
    orEmail: 'or email hello@receptionmate.co.uk',
    billing: 'Simple monthly billing',
  },
  fr: {
    eyebrow: 'Prêt quand vous l’êtes',
    h2: 'Écoutez Leah répondre à votre téléphone.',
    sub: 'Indiquez le nom de votre entreprise et votre e-mail — Assist est opérationnel en quelques minutes.',
    getStarted: 'Commencer',
    orEmail: 'ou écrivez à hello@receptionmate.co.uk',
    billing: 'Facturation mensuelle simple',
  },
}[lang];
---

<section id="get-started" class="relative bg-brand-600 py-20 sm:py-28">
  <div class="absolute inset-0 -z-10 overflow-hidden">
    <div class="absolute -top-32 -left-32 h-96 w-96 rounded-full bg-brand-400/30 blur-3xl"></div>
    <div class="absolute -bottom-32 right-0 h-96 w-96 rounded-full bg-fuchsia-400/20 blur-3xl"></div>
  </div>

  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
    <p class="text-sm font-semibold uppercase tracking-wider text-brand-200">{c.eyebrow}</p>
    <h2 class="mt-3 text-3xl font-bold tracking-tight text-white sm:text-4xl">
      {c.h2}
    </h2>
    <p class="mt-3 text-base text-brand-100">
      {c.sub}
    </p>
    <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <a
        href="#hero-lead-form"
        class="inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3.5 text-base font-semibold text-brand-600 shadow-lg shadow-brand-900/30 hover:bg-brand-50 transition"
      >
        {c.getStarted}
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
      </a>
      <a href="mailto:hello@receptionmate.co.uk" class="text-sm font-medium text-brand-100 hover:text-white">
        {c.orEmail}
      </a>
    </div>
    <p class="mt-4 text-xs text-brand-200">
      {c.billing}
    </p>
  </div>
</section>
