---
const quotes = [
  {
    quote: "We were losing two or three bookings a day to missed calls. ReceptionMate caught all of them in the first week — it pays for itself by Tuesday.",
    name: "Daniel Tyldesley",
    role: "Director, EAC Telford",
  },
  {
    quote: "The team can actually focus on the work now. Leah deals with the noise — quote requests, callbacks, MOT bookings — and only puts the proper ones through.",
    name: "Owner",
    role: "St Johns Garage",
  },
  {
    quote: "Set up in a day. Honestly didn't expect it to handle northeast accents this well.",
    name: "Branch Manager",
    role: "In'n'out Autocentres",
  },
];
---

<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">From the workshop floor</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Real garages, real results.
      </h2>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {quotes.map((q) => (
        <figure class="flex flex-col justify-between rounded-2xl border border-ink-200 bg-ink-50 p-6">
          <blockquote class="text-base text-ink-800">
            <p class="leading-relaxed">"{q.quote}"</p>
          </blockquote>
          <figcaption class="mt-6 border-t border-ink-200 pt-4">
            <p class="text-sm font-semibold text-ink-900">{q.name}</p>
            <p class="text-xs text-ink-500">{q.role}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
