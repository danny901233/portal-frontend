---
// Verbatim quotes from real case-study customers. If you update one of the
// case studies on /case-studies, keep these aligned — they're the same words.
// `result` is the factual outcome row shown under the quote — not invented
// text, drawn from the corresponding case study.
const quotes = [
  {
    quote: "Over the 2 months (Oct / Nov) looking at the uplift in sales from the final invoice value and deducting your invoices, INO have generated an additional £21k that would have otherwise been lost sales.",
    name: "Louise",
    role: "In'n'Out Autocentres",
    result: "992 calls answered · 245 bookings captured · £34,089 revenue",
  },
  {
    quote: "Bookings we would have lost are now in our diary the next morning.",
    name: "Mark",
    role: "EAC Telford",
    result: "1,468 calls answered · 158 bookings captured · £28,761 revenue",
  },
];
---

<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">From the workshop floor</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Real garages, real results.
      </h2>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl gap-6 md:grid-cols-2">
      {quotes.map((q) => (
        <figure class="flex flex-col justify-between rounded-2xl border border-ink-200 bg-ink-50 p-6">
          <blockquote class="text-base text-ink-800">
            <p class="leading-relaxed">"{q.quote}"</p>
          </blockquote>
          <figcaption class="mt-6 border-t border-ink-200 pt-4">
            <p class="text-sm font-semibold text-ink-900">{q.name}</p>
            <p class="text-xs text-ink-500">{q.role}</p>
            {q.result && (
              <p class="mt-2 text-xs font-medium text-brand-700">{q.result}</p>
            )}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
