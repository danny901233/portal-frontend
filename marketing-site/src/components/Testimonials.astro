---
// Verbatim quotes from real case-study customers. If you update one of the
// case studies on /case-studies, keep these aligned — they're the same words.
// `result` is the factual outcome row shown under the quote — not invented
// text, drawn from the corresponding case study.
import { getLang, L } from '../i18n/ui';
const lang = getLang(Astro.url);
const c = {
  en: {
    eyebrow: 'From the workshop floor',
    h2: 'Real garages, real results.',
    quotes: [
      {
        quote: "Over the 2 months (Oct / Nov) looking at the uplift in sales from the final invoice value and deducting your invoices, INO have generated an additional £21k that would have otherwise been lost sales.",
        name: "Louise",
        role: "In'n'Out Autocentres",
        result: "992 calls answered · 245 bookings captured · £34,089 revenue",
      },
      {
        quote: "Bookings we would have lost are now in our diary the next morning.",
        name: "Mark",
        role: "EAC Telford",
        result: "1,468 calls answered · 158 bookings captured · £28,761 revenue",
      },
    ],
  },
  fr: {
    eyebrow: "Depuis l'atelier",
    h2: 'De vrais garages, de vrais résultats.',
    quotes: [
      {
        quote: "Sur les 2 mois (oct. / nov.), en analysant la hausse des ventes à partir de la valeur des factures finales et en déduisant vos factures, INO a généré 21 000 £ supplémentaires qui auraient sinon été des ventes perdues.",
        name: "Louise",
        role: "In'n'Out Autocentres",
        result: "992 appels traités · 245 réservations enregistrées · 34 089 £ de chiffre d'affaires",
      },
      {
        quote: "Les réservations que nous aurions perdues figurent désormais dans notre agenda dès le lendemain matin.",
        name: "Mark",
        role: "EAC Telford",
        result: "1 468 appels traités · 158 réservations enregistrées · 28 761 £ de chiffre d'affaires",
      },
    ],
  },
}[lang];
const quotes = c.quotes;
---

<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.eyebrow}</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        {c.h2}
      </h2>
    </div>

    <div class="mx-auto mt-14 grid max-w-5xl gap-6 md:grid-cols-2">
      {quotes.map((q) => (
        <figure class="flex flex-col justify-between rounded-2xl border border-ink-200 bg-white p-6 shadow-sm">
          <!-- Review-style header: avatar initial + name + 5-star rating, looks like a TrustPilot/Google review. -->
          <header class="flex items-center gap-3">
            <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-brand-600 text-base font-bold text-white">
              {q.name.charAt(0)}
            </span>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-ink-900">{q.name}</p>
              <p class="text-xs text-ink-500">{q.role}</p>
            </div>
            <div class="flex items-center gap-0.5 text-amber-500" aria-label={lang === 'fr' ? '5 étoiles sur 5' : '5 out of 5 stars'}>
              {Array.from({ length: 5 }).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 15.27L16.18 19l-1.64-7.03L20 7.24l-7.19-.61L10 0 7.19 6.63 0 7.24l5.46 4.73L3.82 19z"/></svg>
              ))}
            </div>
          </header>
          <blockquote class="mt-5 text-base text-ink-800">
            <p class="leading-relaxed">"{q.quote}"</p>
          </blockquote>
          {q.result && (
            <p class="mt-5 border-t border-ink-200 pt-4 text-xs font-medium text-brand-700">{q.result}</p>
          )}
        </figure>
      ))}
    </div>
  </div>
</section>
