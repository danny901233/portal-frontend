---
const tiers = [
  {
    name: 'Assist',
    icon: 'phone',
    badge: 'Live in minutes',
    badgeStyle: 'bg-emerald-100 text-emerald-700',
    price: '£200',
    priceUnit: '/month',
    priceFootnote: '400 minutes included · £0.25 / overage minute',
    headline: 'Catch every call, capture every job.',
    body: "Leah answers your unanswered calls, takes the customer's name, vehicle, service and number, and sends the job to your team. No integration required.",
    bullets: [
      'Live in minutes — no integration needed',
      'Calls, transcripts and job details in the portal',
      'SMS confirmations to the customer',
      'Perfect for small workshops and single-receptionist garages',
    ],
    cta: 'Start with Assist',
    href: '/get-started?tier=assist',
    accent: 'border-ink-200 bg-white',
    recommended: false,
  },
  {
    name: 'Automate',
    icon: 'spark',
    badge: '3–5 day setup',
    badgeStyle: 'bg-brand-100 text-brand-700',
    price: 'Custom',
    priceUnit: '',
    priceFootnote: 'Based on branches & integration',
    headline: 'Books the job, in your diary.',
    body: "Everything in Assist, plus Leah integrates directly with your booking system — picks the slot, books the job, holds the bay. Customer hangs up with a confirmed appointment.",
    bullets: [
      'Integrates with Garage Hive, HubSpot and others',
      'Reserves real slots in real time — no double-bookings',
      'Quotes prices on the call from your service menu',
      'Automatic SMS reminders + same-day confirmations',
      'Built for busy multi-bay and multi-branch operations',
    ],
    cta: 'Talk to us about Automate',
    href: '/get-started?tier=automate',
    accent: 'border-brand-200 bg-gradient-to-br from-brand-50/60 to-white ring-2 ring-brand-600',
    recommended: true,
  },
  {
    name: 'Connect',
    icon: 'chat',
    badge: '3–5 day setup',
    badgeStyle: 'bg-sky-100 text-sky-700',
    price: 'Talk to us',
    priceUnit: '',
    priceFootnote: 'Pricing based on contact volume',
    headline: 'Inbound from every channel. Outbound that books itself.',
    body: "ReceptionMate answers messages across web chat, WhatsApp, Instagram and Facebook — and sends opted-in MOT and service reminders that book customers in without anyone in the workshop lifting a finger.",
    bullets: [
      'Web chat widget on your garage website',
      'WhatsApp, Instagram and Facebook DMs handled automatically',
      'Outbound MOT and service reminders that book in-thread',
      'All conversations land in the same ReceptionMate inbox',
      'For garages who want messaging working as hard as the phone',
    ],
    cta: 'Talk to us about Connect',
    href: '/get-started?tier=connect',
    accent: 'border-ink-200 bg-white',
    recommended: false,
  },
];

const iconMap: Record<string, string> = {
  phone: 'M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z',
  chat:  'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
  spark: 'M13 10V3L4 14h7v7l9-11h-7z',
};
---

<section class="bg-white py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">Three ways to start</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Pick the tier that fits your garage.
      </h2>
      <p class="mt-4 text-lg text-ink-600">
        All three are billed monthly with no minimum contract. Most garages move quickly to Automate
        once they see the volume — you can switch any time.
      </p>
    </div>

    <div class="mt-16 grid gap-6 lg:grid-cols-3 lg:items-stretch">
      {tiers.map((t) => (
        <article class={`relative flex flex-col rounded-2xl border p-6 shadow-sm transition hover:shadow-lg hover:shadow-brand-900/5 ${t.accent} ${t.recommended ? 'lg:-my-2' : ''}`}>
          {t.recommended && (
            <span class="absolute -top-3 left-1/2 inline-flex -translate-x-1/2 items-center gap-1 rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-white shadow">
              Most popular
            </span>
          )}

          <div class="flex items-center gap-3">
            <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-brand-50 text-brand-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[t.icon]} />
              </svg>
            </span>
            <div>
              <h3 class="text-xl font-bold text-ink-900">{t.name}</h3>
              <span class={`mt-0.5 inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold ${t.badgeStyle}`}>{t.badge}</span>
            </div>
          </div>

          <!-- Price block -->
          <div class="mt-5 pb-5 border-b border-ink-200">
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold text-ink-900">{t.price}</span>
              {t.priceUnit && <span class="text-base font-medium text-ink-500">{t.priceUnit}</span>}
            </div>
            {t.priceFootnote && (
              <p class="mt-1 text-xs text-ink-500">{t.priceFootnote}</p>
            )}
          </div>

          <p class="mt-5 text-base font-semibold text-ink-900">{t.headline}</p>
          <p class="mt-2 text-sm text-ink-600">{t.body}</p>

          <ul class="mt-5 space-y-2.5 text-sm text-ink-700">
            {t.bullets.map((b, idx) => (
              <li class={`flex gap-2.5 ${idx >= 3 ? 'hidden lg:flex' : ''}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
                <span>{b}</span>
              </li>
            ))}
          </ul>

          <div class="mt-6 pt-5 border-t border-ink-200">
            <a
              href={t.href}
              class={t.recommended
                ? 'inline-flex w-full items-center justify-center gap-2 rounded-xl bg-brand-600 px-4 py-3 text-sm font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-700 transition'
                : 'inline-flex w-full items-center justify-center gap-2 rounded-xl border border-ink-300 bg-white px-4 py-3 text-sm font-semibold text-ink-900 hover:border-brand-300 hover:text-brand-700 transition'
              }>
              {t.cta}
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>

    <p class="mt-8 text-center text-sm text-ink-500">
      Not sure which? Start with Assist — we'll help you graduate to Automate when you're ready.
    </p>
  </div>
</section>
