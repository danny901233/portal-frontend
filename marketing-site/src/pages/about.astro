---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyUs from '../components/WhyUs.astro';

const values = [
  {
    title: 'Built by people who answer the phone',
    body: "We're not a generic AI vendor. We grew up around garages — we know what 'book it in for an interim' means, what an MOT cost is in 2026, why drop-offs are a problem on Saturday mornings.",
  },
  {
    title: 'Tuned to UK voices',
    body: "Trained and tested against UK accents, registration plate phrasings, and the specific vocabulary of automotive — not retrofitted from an American product.",
  },
  {
    title: "Honest about what AI can and can't do",
    body: "When Leah hits her limit, she puts the call through to a human. We tell you what she handled and what she didn't — and the portal shows you every transcript.",
  },
  {
    title: 'Your data, your customers',
    body: 'Calls, transcripts, customer details all live in your portal — exportable, deletable. No sharing with third parties, no training on your data without permission.',
  },
];

const milestones = [
  { year: '2024', text: 'First customer goes live with an early prototype.' },
  { year: '2025', text: "Roll out across the In'n'out Autocentres group." },
  { year: '2026', text: 'Three specialist agents (Leah, Tom, Sophie) ship. 1,000+ calls handled weekly.' },
];
---

<BaseLayout
  title="Why ReceptionMate — Built for UK garages"
  description="ReceptionMate is built by people who grew up around UK garages. Tuned to British voices, honest about what AI can do, and your data stays yours."
>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 h-96 w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-5xl px-4 pt-20 pb-12 sm:px-6 lg:px-8 lg:pt-24">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">Why ReceptionMate</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        We answer the calls<br/>
        <span class="text-brand-600">your team can't.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-600">
        Most AI receptionists are built for nail salons, dentists, and law firms — then sold to garages
        as an afterthought. ReceptionMate was built for automotive from day one, by people who knew
        garages were missing 30% of their calls and nobody had a real fix.
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-ink-200 bg-white p-8 sm:p-10">
        <h2 class="text-2xl font-bold text-ink-900">The problem we wouldn't let go</h2>
        <div class="mt-4 space-y-4 text-base leading-relaxed text-ink-700">
          <p>
            With over a decade working inside automotive garages and main-dealer service departments,
            we've watched the same problem play out at every site — phones ringing during the lunchtime
            rush, diaries scribbled over twice, and the receptionist getting blamed when a booking fell
            through the cracks.
          </p>
          <p>
            What we found wasn't a software problem. It was a <em>physics</em> problem.
            One receptionist. Three lines. A workshop full of cars. The phone rings while she's already
            on a call, or she's gone to lunch, or she's chasing a tech for a quote. The customer hangs up
            and rings the next garage on Google.
          </p>
          <p>
            Existing answering services took messages — they didn't book jobs. Voicemails got ignored.
            Receptionist-as-a-service costs three times what a missed booking is worth and still doesn't
            scale on a Monday morning.
          </p>
          <p class="font-semibold text-ink-900">
            So we built an AI receptionist that books the job on the call. Not a transcript, not a message —
            a booking, in your diary, with the customer confirmed by text before they've put the kettle on.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">What we believe</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
          Four things that shape what we build.
        </h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {values.map((v) => (
          <div class="rounded-2xl border border-ink-200 bg-ink-50 p-6">
            <h3 class="text-lg font-semibold text-ink-900">{v.title}</h3>
            <p class="mt-2 text-base text-ink-700">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison vs alternatives -->
  <WhyUs />

  <!-- Timeline -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-ink-900">How we got here.</h2>
      <ul class="mt-8 space-y-6">
        {milestones.map((m) => (
          <li class="flex gap-4">
            <span class="shrink-0 rounded-lg bg-brand-600 px-3 py-1 font-mono text-sm font-bold text-white">{m.year}</span>
            <p class="text-base text-ink-700">{m.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-brand-600 p-10 text-center sm:p-14">
        <div class="absolute inset-0 -z-10">
          <div class="absolute -top-32 -left-32 h-72 w-72 rounded-full bg-brand-400/30 blur-3xl"></div>
          <div class="absolute -bottom-32 right-0 h-72 w-72 rounded-full bg-fuchsia-400/20 blur-3xl"></div>
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          See Leah answer your phone.
        </h2>
        <p class="mt-3 text-base text-brand-100">
          Drop your details and Assist goes live in minutes. Hear it answer your phone yourself.
        </p>
        <div class="mt-6">
          <a href="/#hero-lead-form" class="inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3.5 text-base font-semibold text-brand-600 shadow-lg shadow-brand-900/30 hover:bg-brand-50 transition">
            Get started
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
