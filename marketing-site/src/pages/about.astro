---
import BaseLayout from '../layouts/BaseLayout.astro';
import WhyUs from '../components/WhyUs.astro';
import { getLang, L } from '../i18n/ui';
const lang = getLang(Astro.url);

const c = {
  en: {
    metaTitle: 'Why ReceptionMate — Built for UK garages',
    metaDescription: 'ReceptionMate is built by people who grew up around UK garages. Tuned to British voices, honest about what AI can do, and your data stays yours.',
    kicker: 'Why ReceptionMate',
    h1a: 'We answer the calls',
    h1b: `your team can't.`,
    heroSubMobile: 'Built for automotive from day one. The only AI receptionist designed specifically for UK garages.',
    heroSubDesktop: `Most AI receptionists are built for nail salons, dentists, and law firms — then sold to garages as an afterthought. ReceptionMate was built for automotive from day one, by people who knew garages were missing 30% of their calls and nobody had a real fix.`,
    storyH2: `The problem we wouldn't let go`,
    storyMobile: `With over a decade working inside UK garages, we watched the same problem play out at every site — phones ringing during the lunchtime rush, bookings slipping through the cracks, customers calling the next garage on Google.`,
    storyP1: `With over a decade working inside automotive garages and main-dealer service departments, we've watched the same problem play out at every site — phones ringing during the lunchtime rush, diaries scribbled over twice, and the receptionist getting blamed when a booking fell through the cracks.`,
    storyP3: `Existing answering services took messages — they didn't book jobs. Voicemails got ignored. Receptionist-as-a-service costs three times what a missed booking is worth and still doesn't scale on a Monday morning.`,
    storyP4: `So we built an AI receptionist that books the job on the call. Not a transcript, not a message — a booking, in your diary, with the customer confirmed by text before they've put the kettle on.`,
    valuesKicker: 'What we believe',
    valuesH2: 'Four things that shape what we build.',
    values: [
      {
        title: 'Built by people who answer the phone',
        body: "We're not a generic AI vendor. We grew up around garages — we know what 'book it in for an interim' means, what an MOT cost is in 2026, why drop-offs are a problem on Saturday mornings.",
      },
      {
        title: 'Tuned to UK voices',
        body: "Trained and tested against UK accents, registration plate phrasings, and the specific vocabulary of automotive — not retrofitted from an American product.",
      },
      {
        title: "Honest about what AI can and can't do",
        body: "When Leah hits her limit, she puts the call through to a human. We tell you what she handled and what she didn't — and the portal shows you every transcript.",
      },
      {
        title: 'Your data, your customers',
        body: 'Calls, transcripts, customer details all live in your portal — exportable, deletable. No sharing with third parties, no training on your data without permission.',
      },
    ],
    ctaH2: 'See Leah answer your phone.',
    ctaSub: 'Drop your details and Assist goes live in minutes. Hear it answer your phone yourself.',
    getStarted: 'Get started',
  },
  fr: {
    metaTitle: 'Pourquoi ReceptionMate — Conçu pour les garages',
    metaDescription: 'ReceptionMate est conçu par des personnes qui ont grandi autour des garages. Adapté aux voix britanniques, honnête sur ce que l’IA peut faire, et vos données restent les vôtres.',
    kicker: 'Pourquoi ReceptionMate',
    h1a: 'Nous répondons aux appels',
    h1b: `que votre équipe ne peut pas prendre.`,
    heroSubMobile: 'Conçu pour l’automobile dès le premier jour. La seule réceptionniste IA pensée spécifiquement pour les garages.',
    heroSubDesktop: `La plupart des réceptionnistes IA sont conçues pour les salons de manucure, les dentistes et les cabinets d’avocats — puis vendues aux garages en dernier recours. ReceptionMate a été conçue pour l’automobile dès le premier jour, par des personnes qui savaient que les garages manquaient 30 % de leurs appels sans qu’aucune vraie solution n’existe.`,
    storyH2: `Le problème que nous n’avons pas voulu laisser passer`,
    storyMobile: `Avec plus d’une décennie passée au sein des garages, nous avons vu le même problème se répéter sur chaque site — des téléphones qui sonnent en plein rush du déjeuner, des réservations qui passent à travers les mailles du filet, des clients qui appellent le garage suivant sur Google.`,
    storyP1: `Avec plus d’une décennie passée au sein de garages automobiles et de services après-vente de concessions, nous avons vu le même problème se répéter sur chaque site — des téléphones qui sonnent en plein rush du déjeuner, des agendas raturés deux fois, et la réceptionniste tenue pour responsable quand une réservation passait à travers les mailles du filet.`,
    storyP3: `Les services de permanence téléphonique existants prenaient des messages — ils ne réservaient pas les interventions. Les messages vocaux étaient ignorés. La réceptionniste en tant que service coûte trois fois la valeur d’une réservation manquée et ne tient toujours pas la charge un lundi matin.`,
    storyP4: `Nous avons donc conçu une réceptionniste IA qui réserve l’intervention pendant l’appel. Pas une transcription, pas un message — une réservation, dans votre agenda, avec le client confirmé par SMS avant même qu’il ait mis la bouilloire en route.`,
    valuesKicker: 'Ce en quoi nous croyons',
    valuesH2: 'Quatre principes qui façonnent ce que nous construisons.',
    values: [
      {
        title: 'Conçu par des gens qui répondent au téléphone',
        body: "Nous ne sommes pas un fournisseur d’IA générique. Nous avons grandi autour des garages — nous savons ce que signifie « le programmer pour une révision intermédiaire », combien coûte un contrôle technique en 2026, et pourquoi les dépôts de véhicule posent problème le samedi matin.",
      },
      {
        title: 'Adapté aux voix britanniques',
        body: "Entraîné et testé sur les accents britanniques, les formulations de plaques d’immatriculation et le vocabulaire spécifique de l’automobile — et non adapté à la hâte depuis un produit américain.",
      },
      {
        title: "Honnête sur ce que l’IA peut et ne peut pas faire",
        body: "Lorsque Leah atteint ses limites, elle transfère l’appel à un humain. Nous vous disons ce qu’elle a géré et ce qu’elle n’a pas géré — et le portail vous montre chaque transcription.",
      },
      {
        title: 'Vos données, vos clients',
        body: 'Les appels, les transcriptions et les coordonnées des clients se trouvent tous dans votre portail — exportables, supprimables. Aucun partage avec des tiers, aucun entraînement sur vos données sans autorisation.',
      },
    ],
    ctaH2: 'Écoutez Leah répondre à votre téléphone.',
    ctaSub: 'Laissez vos coordonnées et Assist passe en direct en quelques minutes. Entendez-la répondre à votre téléphone vous-même.',
    getStarted: 'Commencer',
  },
}[lang];
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 h-96 w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"></div>
    </div>

    <!-- Mobile: centred. Desktop: left-aligned (unchanged). -->
    <div class="mx-auto max-w-5xl px-4 pt-20 pb-12 text-center sm:px-6 lg:px-8 lg:pt-24 lg:text-left">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.kicker}</p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        {c.h1a}<br/>
        <span class="text-brand-600">{c.h1b}</span>
      </h1>
      <!-- Mobile: one short sentence. Desktop: full positioning paragraph. -->
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-ink-600 lg:mx-0 lg:hidden">
        {c.heroSubMobile}
      </p>
      <p class="mx-auto mt-6 hidden max-w-2xl text-lg leading-relaxed text-ink-600 lg:mx-0 lg:block">
        {c.heroSubDesktop}
      </p>
    </div>
  </section>

  <!-- Story -->
  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <!-- Mobile: centred text + smaller padding; desktop: left-aligned (unchanged). -->
      <div class="rounded-2xl border border-ink-200 bg-white p-6 text-center sm:p-10 lg:text-left">
        <h2 class="text-2xl font-bold text-ink-900">{c.storyH2}</h2>
        <div class="mt-4 space-y-4 text-base leading-relaxed text-ink-700">
          <!-- Short version for mobile. -->
          <p class="md:hidden">
            {c.storyMobile}
          </p>
          <!-- Full story for tablet + desktop. -->
          <p class="hidden md:block">
            {c.storyP1}
          </p>
          <p class="hidden md:block" set:html={lang === 'fr'
            ? `Ce que nous avons découvert n’était pas un problème de logiciel. C’était un problème de <em>physique</em>. Une réceptionniste. Trois lignes. Un atelier plein de voitures. Le téléphone sonne alors qu’elle est déjà en ligne, ou qu’elle est partie déjeuner, ou qu’elle relance un technicien pour un devis. Le client raccroche et appelle le garage suivant sur Google.`
            : `What we found wasn't a software problem. It was a <em>physics</em> problem. One receptionist. Three lines. A workshop full of cars. The phone rings while she's already on a call, or she's gone to lunch, or she's chasing a tech for a quote. The customer hangs up and rings the next garage on Google.`
          }>
          </p>
          <p class="hidden md:block">
            {c.storyP3}
          </p>
          <p class="font-semibold text-ink-900">
            {c.storyP4}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.valuesKicker}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
          {c.valuesH2}
        </h2>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {c.values.map((v) => (
          <div class="rounded-2xl border border-ink-200 bg-ink-50 p-6 text-center md:text-left">
            <h3 class="text-lg font-semibold text-ink-900">{v.title}</h3>
            <p class="mt-2 text-base text-ink-700">{v.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison vs alternatives -->
  <WhyUs />


  <!-- CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="relative overflow-hidden rounded-3xl bg-brand-600 p-10 text-center sm:p-14">
        <div class="absolute inset-0 -z-10">
          <div class="absolute -top-32 -left-32 h-72 w-72 rounded-full bg-brand-400/30 blur-3xl"></div>
          <div class="absolute -bottom-32 right-0 h-72 w-72 rounded-full bg-fuchsia-400/20 blur-3xl"></div>
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {c.ctaH2}
        </h2>
        <p class="mt-3 text-base text-brand-100">
          {c.ctaSub}
        </p>
        <div class="mt-6">
          <a href={`${L('/', lang)}#hero-lead-form`} class="inline-flex items-center gap-2 rounded-xl bg-white px-5 py-3.5 text-base font-semibold text-brand-600 shadow-lg shadow-brand-900/30 hover:bg-brand-50 transition">
            {c.getStarted}
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z" clip-rule="evenodd"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
