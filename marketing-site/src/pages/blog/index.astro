---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  title="Blog — ReceptionMate"
  description="Practical guides and insight for UK garage owners on AI receptionists, missed calls, MOT season, and growing a workshop."
>
  <section class="bg-white pt-16 pb-10 sm:pt-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">Blog</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        Practical reads for UK garage owners.
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-700">
        Guides, comparisons and insight from inside the UK automotive aftermarket — the
        kind of stuff we wish someone had written when we started.
      </p>
    </div>
  </section>

  <section class="bg-ink-50 py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="rounded-2xl border border-ink-200 bg-white p-10 text-center">
          <p class="text-ink-700">First posts publishing shortly — check back soon.</p>
        </div>
      ) : (
        <ol class="grid gap-5">
          {posts.map((post) => (
            <li>
              <a
                href={`/blog/${post.id}`}
                class="group block overflow-hidden rounded-2xl border border-ink-200 bg-white transition hover:border-brand-300 hover:shadow-md"
              >
                {post.data.heroImage && (
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? ''}
                    class="aspect-[16/9] w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <div class="p-6 sm:p-8">
                  <div class="flex flex-wrap items-center gap-2 text-xs">
                    <span class="text-ink-500">{formatDate(post.data.publishedAt)}</span>
                    {post.data.tags.slice(0, 3).map((t) => (
                      <span class="rounded-full bg-brand-50 px-2.5 py-1 font-semibold text-brand-700">
                        {t}
                      </span>
                    ))}
                  </div>
                  <h2 class="mt-3 text-xl font-bold text-ink-900 group-hover:text-brand-700 sm:text-2xl">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-base leading-relaxed text-ink-700">{post.data.description}</p>
                  <p class="mt-4 text-sm font-semibold text-brand-700 group-hover:text-brand-800">
                    Read post →
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>
</BaseLayout>
