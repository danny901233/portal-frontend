---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getLang, L } from '../../i18n/ui';

const lang = getLang(Astro.url);

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const formatDate = (d: Date) =>
  d.toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const c = {
  en: {
    metaTitle: 'Blog — ReceptionMate',
    metaDesc: 'Practical guides and insight for UK garage owners on AI receptionists, missed calls, MOT season, and growing a workshop.',
    eyebrow: 'Blog',
    h1: 'Practical reads for UK garage owners.',
    intro: 'Guides, comparisons and insight from inside the UK automotive aftermarket — the kind of stuff we wish someone had written when we started.',
    empty: 'First posts publishing shortly — check back soon.',
    readPost: 'Read post →',
  },
  fr: {
    metaTitle: 'Blog — ReceptionMate',
    metaDesc: 'Guides pratiques et analyses pour les gérants de garage : réceptionnistes IA, appels manqués, saison du contrôle technique et développement de l’atelier.',
    eyebrow: 'Blog',
    h1: 'Des lectures pratiques pour les gérants de garage.',
    intro: 'Guides, comparatifs et analyses issus du secteur de l’après-vente automobile — le genre de contenu que nous aurions aimé lire à nos débuts.',
    empty: 'Les premiers articles paraissent bientôt — revenez vite.',
    readPost: 'Lire l’article →',
  },
}[lang];
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDesc}
>
  <section class="bg-white pt-16 pb-10 sm:pt-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.eyebrow}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        {c.h1}
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-700">
        {c.intro}
      </p>
    </div>
  </section>

  <section class="bg-ink-50 py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      {posts.length === 0 ? (
        <div class="rounded-2xl border border-ink-200 bg-white p-10 text-center">
          <p class="text-ink-700">{c.empty}</p>
        </div>
      ) : (
        <ol class="grid gap-5">
          {posts.map((post) => (
            <li>
              <a
                href={L(`/blog/${post.id}`, lang)}
                class="group block overflow-hidden rounded-2xl border border-ink-200 bg-white transition hover:border-brand-300 hover:shadow-md"
              >
                {post.data.heroImage && (
                  <img
                    src={post.data.heroImage}
                    alt={post.data.heroImageAlt ?? ''}
                    class="aspect-[16/9] w-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                )}
                <div class="p-6 sm:p-8">
                  <div class="flex flex-wrap items-center gap-2 text-xs">
                    <span class="text-ink-500">{formatDate(post.data.publishedAt)}</span>
                    {post.data.tags.slice(0, 3).map((t) => (
                      <span class="rounded-full bg-brand-50 px-2.5 py-1 font-semibold text-brand-700">
                        {t}
                      </span>
                    ))}
                  </div>
                  <h2 class="mt-3 text-xl font-bold text-ink-900 group-hover:text-brand-700 sm:text-2xl">
                    {post.data.title}
                  </h2>
                  <p class="mt-2 text-base leading-relaxed text-ink-700">{post.data.description}</p>
                  <p class="mt-4 text-sm font-semibold text-brand-700 group-hover:text-brand-800">
                    {c.readPost}
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>
</BaseLayout>
