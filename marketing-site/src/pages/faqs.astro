---
import BaseLayout from '../layouts/BaseLayout.astro';

// FAQs are grouped for navigation but flattened for JSON-LD because Google's
// FAQPage schema is a flat list. Keep answers plain text (no HTML) — JSON-LD
// strips formatting anyway.

interface FAQ { q: string; a: string; }

const groups: { title: string; items: FAQ[] }[] = [
  {
    title: 'About ReceptionMate',
    items: [
      {
        q: 'What is ReceptionMate?',
        a: 'ReceptionMate is an AI receptionist built specifically for UK garages. It answers your phone calls, captures bookings directly into your garage management system (Garage Hive, Tyresoft and others), confirms the customer by text, and logs everything in a portal you can review. It handles aftersales bookings, sales enquiries and general reception calls.',
      },
      {
        q: 'Who is ReceptionMate built for?',
        a: 'Independent garages, multi-site service groups, MOT centres, tyre shops, body shops and main-dealer aftersales departments — anywhere in the UK where a workshop is busier than the receptionist can comfortably handle.',
      },
      {
        q: 'How is ReceptionMate different from generic AI receptionists?',
        a: 'Most AI receptionists are general-purpose tools sold across nail salons, dentists, law firms and garages. ReceptionMate was built for UK automotive from day one — it knows MOT cycles, can read UK registration plates spoken the way British drivers say them, understands service vocabulary (interim, cambelt, DPF), and integrates directly with Garage Hive and Tyresoft.',
      },
    ],
  },
  {
    title: 'Setup and going live',
    items: [
      {
        q: 'Do I need to change my phone number?',
        a: 'No. You keep your existing number. We provision a ReceptionMate number, and you set call forwarding on your existing landline or mobile: if a call rings 5–7 times without anyone picking up, it forwards to ReceptionMate. Out of hours, every call forwards automatically. Your team still answers first when they can.',
      },
      {
        q: 'How long does setup take?',
        a: 'Most garages are up and running within an hour. We pull your services, hours and prices from your Google Business Profile and website, you confirm the details, and the call-forwarding rule is configured by your telco the same day.',
      },
      {
        q: 'Can I test it before going live?',
        a: 'Yes — we set you up with a live test number so you can call in and throw any tricky booking at the agent. The call, the transcript and any captured booking appear in your portal in real time. If anything is off, you tune the agent\'s behaviour from the portal before switching the forwarding on.',
      },
      {
        q: 'Do I need any new hardware?',
        a: 'No. ReceptionMate runs entirely in the cloud. You use your existing phone, your existing garage management system, and a browser to see the portal.',
      },
    ],
  },
  {
    title: 'How it works on a call',
    items: [
      {
        q: 'Can ReceptionMate actually book a job, or does it just take a message?',
        a: 'It books the job live during the call. It reads your diary, offers free slots, reserves the chosen one in real time, and confirms by SMS before the call ends. Messages and callbacks are also possible when the customer prefers — but the default behaviour is to capture the booking on the call.',
      },
      {
        q: 'Does it understand UK accents and registration plates?',
        a: 'Yes. ReceptionMate is trained on real UK garage calls — Scouse, Glaswegian, Geordie, West Country and everything in between — and captures number plates the way drivers actually phrase them (mixed letters, digit words and NATO alphabet, sometimes in the same sentence).',
      },
      {
        q: 'What if a call is complex or needs a human?',
        a: 'ReceptionMate hands the call to a human when the conversation goes outside what it can confidently handle — complaints, complex diagnostics, or when the caller asks for a specific person. You configure the handover rules in the portal.',
      },
      {
        q: 'Can ReceptionMate look up vehicle details?',
        a: 'Yes. When the caller gives a registration, ReceptionMate pulls make, model, year, fuel type, tax and MOT status from DVLA in under a second — and uses it to confirm the vehicle and quote the right service.',
      },
      {
        q: 'Can it handle multiple calls at once?',
        a: 'Yes. ReceptionMate has unlimited concurrent capacity — a Monday-morning spike, MOT season or a lunchtime queue all get answered instantly. Human services queue or miss calls when their lines are full; AI does not.',
      },
    ],
  },
  {
    title: 'Pricing and contracts',
    items: [
      {
        q: 'How does pricing work?',
        a: 'ReceptionMate is sold as a monthly subscription. Pricing scales with call volume and number of branches — typically less than what a missed booking is worth in a single week. Talk to us via the get-started flow for a quote tailored to your call volume.',
      },
      {
        q: 'Is there a contract?',
        a: 'No long-term contract. You can stop using ReceptionMate at any time — just disable the call-forwarding rule.',
      },
      {
        q: 'Are there hidden per-call or per-minute charges?',
        a: 'No surprises. Your monthly bill is predictable. We tell you up front what\'s included and what happens if you exceed the base allowance.',
      },
    ],
  },
  {
    title: 'Integrations',
    items: [
      {
        q: 'Which garage management systems do you integrate with?',
        a: 'Garage Hive, Tyresoft, and several others — including HubSpot, calendar systems and CRMs. We add new integrations regularly. If you run a system we don\'t support yet, talk to us — most modern DMS platforms have integration paths we can stand up quickly.',
      },
      {
        q: 'Does the booking actually go into my diary?',
        a: 'Yes — written into your DMS during the call, with the customer name, vehicle, service and time slot. No CSV imports, no copy-paste from voicemail transcripts.',
      },
      {
        q: 'Can I send SMS confirmations and reminders?',
        a: 'Yes. SMS confirmations go out as the call ends, and reminders the day before the appointment — reducing no-shows significantly.',
      },
    ],
  },
  {
    title: 'Data and privacy',
    items: [
      {
        q: 'Is ReceptionMate GDPR-compliant?',
        a: 'Yes. ReceptionMate is built and operated to UK GDPR. Call recordings, transcripts and customer details live in your portal, exportable and deletable on request. See our /privacy page for full details on data controllers, sub-processors, retention and your rights.',
      },
      {
        q: 'Where is my data stored?',
        a: 'In UK and EU data centres. International transfers, where they happen for AI inference, use UK IDTA / EU Standard Contractual Clauses. The full sub-processor list is available to customers on request under our Data Processing Agreement.',
      },
      {
        q: 'Are my calls used to train AI models?',
        a: 'No. Customer call data is not used to train third-party models without explicit permission.',
      },
    ],
  },
];

const flatItems = groups.flatMap((g) => g.items);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: flatItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="FAQs — ReceptionMate, the AI receptionist for UK garages"
  description="Frequently asked questions about ReceptionMate — setup, call handling, integrations, pricing and data. Honest answers for UK garage owners."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-white pt-16 pb-10 sm:pt-20 sm:pb-12">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">FAQs</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        Questions UK garage owners ask.
      </h1>
      <p class="mt-4 max-w-2xl text-lg leading-relaxed text-ink-700">
        Straight answers on how ReceptionMate works, what it costs, how setup
        happens, and what we do with your data.
      </p>
    </div>
  </section>

  <!-- FAQ groups -->
  <section class="bg-ink-50 py-12 sm:py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 space-y-12">
      {groups.map((g) => (
        <div>
          <h2 class="text-2xl font-bold text-ink-900">{g.title}</h2>
          <div class="mt-5 space-y-3">
            {g.items.map((f) => (
              <details class="group rounded-2xl border border-ink-200 bg-white p-5 transition open:shadow-md sm:p-6">
                <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-left">
                  <h3 class="text-base font-semibold text-ink-900 sm:text-lg">{f.q}</h3>
                  <span class="mt-1 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-700 transition group-open:rotate-45" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor"><path d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"/></svg>
                  </span>
                </summary>
                <p class="mt-3 text-base leading-relaxed text-ink-700">{f.a}</p>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Lead-in CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        Got a question we haven't answered?
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Email us at <a href="mailto:hello@receptionmate.co.uk" class="text-brand-600 underline">hello@receptionmate.co.uk</a> or
        start the get-started flow — we'll handle the rest by phone or email.
      </p>
      <a href="/get-started" class="mt-8 inline-flex items-center justify-center rounded-md bg-brand-600 px-6 py-3 text-base font-semibold text-white shadow-sm hover:bg-brand-700 transition">
        Get started
      </a>
    </div>
  </section>
</BaseLayout>
