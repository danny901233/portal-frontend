---
// Multi-step "Get started" flow.
//
// Path (all paths walk through Business → Package first):
//   • Assist           → Account → portal redirect
//   • Automate/Connect → GMS question
//     ├─ Garage Hive / Tyresoft → Account + phone → HighLevel lead → "we'll be in touch"
//     └─ Other (or "not sure") → Recommend Assist (capture booking-lead-time +
//                                their actual GMS) → Account → portal,
//                                AND notify the team in HighLevel with the
//                                integration interest so we can follow up.

import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, L } from '../i18n/ui';
const lang = getLang(Astro.url);

