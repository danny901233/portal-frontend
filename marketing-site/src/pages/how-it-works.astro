---
import BaseLayout from '../layouts/BaseLayout.astro';
import HowItWorks from '../components/HowItWorks.astro';
import { getLang, L } from '../i18n/ui';
const lang = getLang(Astro.url);

const c = {
  en: {
    metaTitle: 'How ReceptionMate works — UK garage AI receptionist explained',
    metaDescription: 'See exactly how ReceptionMate answers calls, captures bookings and pushes them into Garage Hive or Tyresoft — step by step, from sign-up to first booking.',
    kicker: 'How it works',
    h1a: 'From sign-up to your',
    h1b: 'first booking — in minutes.',
    heroSub: `ReceptionMate answers calls in a natural UK voice, captures the booking directly into your garage management system, and confirms by text — all on the same call. Here's exactly how it works, end to end.`,
    getStarted: 'Get started',
    stepsH2: 'Walked through, step by step.',
    stepsSub: 'The four things that happen between signing up and your first AI-captured booking. No technical knowledge needed at any point.',
    sections: [
      {
        h2: '1. Sign up in 60 seconds',
        body: `Type your garage name into the receptionmate.co.uk sign-up flow. We pull your services, opening hours, prices and brand details from your existing Google Business Profile and your website — no forms to fill in. You confirm what's right, correct what's wrong, and that's it.`,
      },
      {
        h2: '2. Pick your receptionist\'s voice',
        body: `Three voices, all UK-trained for automotive: Leah (warm, friendly), Tom (efficient, neutral), Sophie (calm, professional). Listen to samples, pick the one that fits your brand. You can change later. The voice you choose is what every caller hears from then on.`,
      },
      {
        h2: '3. Test it on a live number',
        body: `We email you a working test number within a few minutes. Call it. Throw any tricky booking at it — an MOT plus a wheel alignment plus a brake inspection. Watch the call appear in your portal in real time with the transcript, the actions taken, and the booking captured. If anything\'s off, you can tune the agent's behaviour from the portal — no developers needed.`,
      },
      {
        h2: '4. Set up call forwarding, go live',
        body: `You don\'t port your number — you keep it. We give you a ReceptionMate number, and you set conditional call forwarding on your existing landline or mobile: if the call rings 5–7 times without anyone picking up, it forwards to ReceptionMate. Out of hours, every incoming call goes straight to ReceptionMate. Your team still picks up first when they can — ReceptionMate only catches the calls that would have been missed. There\'s no downtime, no contract change with your telco, and you can reverse it in minutes.`,
      },
    ],
    hoodH2: `What's happening behind the scenes.`,
    hoodSub: `You don't need to know any of this to use ReceptionMate — but if you want to understand the moving parts, here's the short version.`,
    hood: [
      {
        title: 'UK telephony',
        body: 'Calls arrive over a UK-based telephony layer with sub-100ms routing. The caller hears the agent pick up as if a human was at the desk.',
      },
      {
        title: 'Voice trained on UK garages',
        body: 'Speech recognition tuned for British accents and garage vocabulary — MOT, advisory, DPF, EGR, cambelt, half-shaft. No "American auto" confusion.',
      },
      {
        title: 'Live DMS integration',
        body: 'Direct integrations with Garage Hive, Tyresoft and others read your diary and write bookings during the call — not at the end of the day.',
      },
      {
        title: 'DVLA + MOT lookups',
        body: 'DVSA / DVLA APIs return vehicle and MOT data in under 200ms, so the agent confirms the right car back to the customer in real time.',
      },
      {
        title: 'SMS confirmations',
        body: 'Bookings trigger an SMS confirmation before the call ends, and a reminder the day before — drastically reducing no-shows.',
      },
      {
        title: 'Your portal',
        body: 'Every call, transcript, booking and message lives in your dashboard. Search, tag, replay, export. Your data, on your terms.',
      },
    ],
    ctaH2: 'See it on your own number.',
    ctaSub: `We'll set you up with a live test line within minutes. Try any kind of booking. If you like what you hear, go live the same week.`,
  },
  fr: {
    metaTitle: 'Comment fonctionne ReceptionMate — la réceptionniste IA pour garages expliquée',
    metaDescription: 'Découvrez exactement comment ReceptionMate répond aux appels, enregistre les réservations et les transmet à Garage Hive ou Tyresoft — étape par étape, de l’inscription à la première réservation.',
    kicker: 'Comment ça marche',
    h1a: 'De l’inscription à votre',
    h1b: 'première réservation — en quelques minutes.',
    heroSub: `ReceptionMate répond aux appels avec une voix naturelle, enregistre la réservation directement dans votre système de gestion de garage et confirme par SMS — le tout pendant le même appel. Voici exactement comment cela fonctionne, de bout en bout.`,
    getStarted: 'Commencer',
    stepsH2: 'Le déroulé, étape par étape.',
    stepsSub: 'Les quatre étapes qui se déroulent entre votre inscription et votre première réservation enregistrée par l’IA. Aucune connaissance technique requise à aucun moment.',
    sections: [
      {
        h2: '1. Inscrivez-vous en 60 secondes',
        body: `Saisissez le nom de votre garage dans le parcours d’inscription sur receptionmate.co.uk. Nous récupérons vos services, vos horaires d’ouverture, vos tarifs et les détails de votre marque depuis votre fiche Google Business Profile existante et votre site web — aucun formulaire à remplir. Vous confirmez ce qui est exact, corrigez ce qui ne l’est pas, et c’est tout.`,
      },
      {
        h2: '2. Choisissez la voix de votre réceptionniste',
        body: `Trois voix, toutes entraînées pour l’automobile : Leah (chaleureuse, sympathique), Tom (efficace, neutre), Sophie (calme, professionnelle). Écoutez des échantillons, choisissez celle qui correspond à votre marque. Vous pourrez en changer plus tard. La voix que vous choisissez est celle que chaque appelant entendra désormais.`,
      },
      {
        h2: '3. Testez-la sur un vrai numéro',
        body: `Nous vous envoyons par e-mail un numéro de test fonctionnel en quelques minutes. Appelez-le. Soumettez-lui n’importe quelle réservation complexe — un contrôle technique plus un parallélisme des roues plus une inspection des freins. Regardez l’appel apparaître dans votre portail en temps réel, avec la transcription, les actions effectuées et la réservation enregistrée. Si quelque chose ne va pas, vous pouvez ajuster le comportement de l’agent depuis le portail — sans développeurs.`,
      },
      {
        h2: '4. Configurez le renvoi d’appels, passez en direct',
        body: `Vous ne portez pas votre numéro — vous le conservez. Nous vous fournissons un numéro ReceptionMate, et vous configurez un renvoi d’appels conditionnel sur votre ligne fixe ou mobile existante : si l’appel sonne 5 à 7 fois sans que personne ne décroche, il est transféré à ReceptionMate. En dehors des heures d’ouverture, chaque appel entrant va directement à ReceptionMate. Votre équipe décroche toujours en priorité quand elle le peut — ReceptionMate ne capte que les appels qui auraient été manqués. Aucune interruption, aucun changement de contrat avec votre opérateur, et vous pouvez l’annuler en quelques minutes.`,
      },
    ],
    hoodH2: `Ce qui se passe en coulisses.`,
    hoodSub: `Vous n’avez pas besoin de connaître tout cela pour utiliser ReceptionMate — mais si vous voulez comprendre les rouages, en voici la version courte.`,
    hood: [
      {
        title: 'Téléphonie',
        body: 'Les appels arrivent via une couche de téléphonie basée au Royaume-Uni avec un routage en moins de 100 ms. L’appelant entend l’agent décrocher comme si une personne était à l’accueil.',
      },
      {
        title: 'Voix entraînée sur les garages',
        body: 'Reconnaissance vocale adaptée aux accents britanniques et au vocabulaire des garages — contrôle technique, avis, FAP, EGR, courroie de distribution, demi-arbre. Aucune confusion « à l’américaine ».',
      },
      {
        title: 'Intégration DMS en direct',
        body: 'Des intégrations directes avec Garage Hive, Tyresoft et d’autres lisent votre agenda et enregistrent les réservations pendant l’appel — pas en fin de journée.',
      },
      {
        title: 'Recherches DVLA + contrôle technique',
        body: 'Les API DVSA / DVLA renvoient les données du véhicule et du contrôle technique en moins de 200 ms, afin que l’agent confirme le bon véhicule au client en temps réel.',
      },
      {
        title: 'Confirmations par SMS',
        body: 'Les réservations déclenchent une confirmation par SMS avant la fin de l’appel, ainsi qu’un rappel la veille — réduisant considérablement les rendez-vous manqués.',
      },
      {
        title: 'Votre portail',
        body: 'Chaque appel, transcription, réservation et message se trouve dans votre tableau de bord. Recherchez, étiquetez, réécoutez, exportez. Vos données, selon vos règles.',
      },
    ],
    ctaH2: 'Découvrez-la sur votre propre numéro.',
    ctaSub: `Nous vous configurons une ligne de test en direct en quelques minutes. Essayez n’importe quel type de réservation. Si ce que vous entendez vous plaît, passez en direct dès la même semaine.`,
  },
}[lang];
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
>

  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-white">
    <div class="absolute inset-0 -z-10">
      <div class="absolute -top-40 left-1/2 h-96 w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"></div>
    </div>
    <div class="mx-auto max-w-5xl px-4 pt-16 pb-12 sm:px-6 lg:px-8 lg:pt-20">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.kicker}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl lg:text-6xl">
        {c.h1a}<br/>
        <span class="text-brand-600">{c.h1b}</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-700">
        {c.heroSub}
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href={L('/get-started', lang)} class="inline-flex items-center justify-center rounded-md bg-brand-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition">
          {c.getStarted}
        </a>
      </div>
    </div>
  </section>

  <!-- Interactive overview reuses the homepage component -->
  <HowItWorks />

  <!-- Step-by-step writeup -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        {c.stepsH2}
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        {c.stepsSub}
      </p>

      <div class="mt-12 space-y-12">
        {c.sections.map((s) => (
          <div>
            <h3 class="text-2xl font-bold text-ink-900">{s.h2}</h3>
            <p class="mt-3 text-base leading-relaxed text-ink-700">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What's happening under the hood -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
        {c.hoodH2}
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        {c.hoodSub}
      </p>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {c.hood.map((h) => (
          <div class="rounded-2xl border border-ink-200 bg-white p-6">
            <h3 class="text-lg font-semibold text-ink-900">{h.title}</h3>
            <p class="mt-2 text-base leading-relaxed text-ink-700">{h.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl bg-brand-600 p-10 text-center sm:p-14">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          {c.ctaH2}
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
          {c.ctaSub}
        </p>
        <div class="mt-8">
          <a href={L('/get-started', lang)} class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow-sm hover:bg-brand-50 transition">
            {c.getStarted}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
