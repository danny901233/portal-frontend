---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLang, L } from '../i18n/ui';

const lang = getLang(Astro.url);

// Three packages, one comparison page. Single source of truth: when a feature
// row moves from ✗ to ✓ for a tier, change it here and the homepage Tiers
// component reads the same conceptual model.

type Mark = boolean | string;

interface Feature {
  group: string;
  label: string;
  detail?: string;
  assist: Mark;
  automate: Mark;
  connect: Mark;
}

const c = {
  en: {
    title: 'Pricing — ReceptionMate packages for UK garages',
    description: 'Three ReceptionMate packages — Assist, Automate and Connect — compared side-by-side. Pick the AI receptionist tier that fits your UK garage.',
    tiers: [
      {
        key: 'assist',
        name: 'Assist',
        tagline: 'Catch every call.',
        price: '£200',
        priceUnit: '/month + VAT',
        priceFootnote: '14-day free trial · 400 minutes included · £0.25 / overage minute',
        cta: 'Start your free trial',
        href: '/get-started?tier=assist',
        recommended: false,
      },
      {
        key: 'automate',
        name: 'Automate',
        tagline: 'Book every job.',
        price: 'Custom',
        priceUnit: '',
        priceFootnote: 'Based on branches & integrations',
        cta: 'Talk to us about Automate',
        href: '/get-started?tier=automate',
        recommended: true,
      },
      {
        key: 'connect',
        name: 'Connect',
        tagline: 'Inbound from every channel. Outbound that books itself.',
        price: 'Talk to us',
        priceUnit: '',
        priceFootnote: 'Pricing based on contact volume',
        cta: 'Talk to us about Connect',
        href: '/get-started?tier=connect',
        recommended: false,
      },
    ],
    features: [
      // VOICE
      { group: 'Voice receptionist', label: 'Answers every inbound call', assist: true, automate: true, connect: false },
      { group: 'Voice receptionist', label: 'Captures customer, vehicle and service details', assist: true, automate: true, connect: false },
      { group: 'Voice receptionist', label: 'DVLA vehicle lookup during the call', detail: 'Make, model, year, fuel type, MOT status — pulled live.', assist: true, automate: true, connect: false },
      { group: 'Voice receptionist', label: 'MOT history checker', assist: true, automate: true, connect: false },
      { group: 'Voice receptionist', label: 'SMS confirmation to the customer', assist: true, automate: true, connect: true },
      { group: 'Voice receptionist', label: 'Books slots straight into your diary', detail: 'Live integration with Garage Hive, Tyresoft, calendars and more.', assist: false, automate: true, connect: false },
      { group: 'Voice receptionist', label: 'Quotes prices from your service menu on the call', assist: false, automate: true, connect: false },
      { group: 'Voice receptionist', label: 'Multi-branch routing', assist: false, automate: true, connect: false },
      // MESSAGING
      { group: 'Messaging (web + social)', label: 'Web chat widget on your garage website', assist: false, automate: false, connect: true },
      { group: 'Messaging (web + social)', label: 'WhatsApp Business inbound', assist: false, automate: false, connect: true },
      { group: 'Messaging (web + social)', label: 'Instagram DM inbound', assist: false, automate: false, connect: true },
      { group: 'Messaging (web + social)', label: 'Facebook Messenger inbound', assist: false, automate: false, connect: true },
      { group: 'Messaging (web + social)', label: 'Outbound MOT and service reminders', detail: 'To opted-in existing customers — books in the same conversation.', assist: false, automate: false, connect: true },
      // PORTAL
      { group: 'Portal & reporting', label: 'All calls, transcripts and messages in one inbox', assist: true, automate: true, connect: true },
      { group: 'Portal & reporting', label: 'Conversation tagging & search', assist: true, automate: true, connect: true },
      { group: 'Portal & reporting', label: 'Weekly performance summary', assist: true, automate: true, connect: true },
      // SUPPORT
      { group: 'Setup & support', label: 'Time to live', assist: 'Minutes', automate: '3–5 days', connect: '3–5 days' },
      { group: 'Setup & support', label: 'Setup help', assist: 'Self-serve', automate: 'White-glove', connect: 'Guided' },
      { group: 'Setup & support', label: 'Minimum contract', assist: 'None', automate: 'None', connect: 'None' },
    ] as Feature[],
    groupOrder: ['Voice receptionist', 'Messaging (web + social)', 'Portal & reporting', 'Setup & support'],
    heroKicker: 'Pricing',
    heroH1: 'Three packages. Pick the one that fits.',
    heroSub: "All packages are billed monthly. Most garages start with Assist or Automate for the voice side, and add Connect when they're ready to take messaging and outbound campaigns on as well.",
    mostPopular: 'Most popular',
    compareKicker: 'Compare',
    compareH2: "What's in each package.",
    featureCol: 'Feature',
    tierTabs: ['Assist', 'Automate', 'Connect'],
    faqH2: 'Pricing FAQ.',
    faqs: [
      { q: 'Can I combine Assist or Automate with Connect?', a: 'Yes. The voice side (Assist or Automate) and the messaging side (Connect) are designed to work together. Most multi-channel garages start with one and add the other.' },
      { q: 'What happens if I exceed the included minutes on Assist?', a: "Overage is billed at £0.25 per minute. We'll flag it in the portal as you approach the included allowance so there are no surprises on your invoice." },
      { q: 'Why is Automate "Custom" priced?', a: "Automate's pricing depends on how many branches you run and which integrations you need (Garage Hive, Tyresoft, custom DMS). Talk to us and we'll give you a fixed monthly number after a short scoping call." },
      { q: 'Is there a contract?', a: 'Simple monthly billing. You can change tier any time — just disable the call-forwarding rule.' },
      { q: 'Do you offer a free trial?', a: 'Yes — Assist comes with a 14-day free trial. You add your card when you sign up but you are not charged until day 14, so you can try it on your real phone line first. Cancel any time before then and you pay nothing.' },
    ],
    ctaH2: 'Not sure which one fits?',
    ctaSub: "A 15-minute call with us is enough to figure it out. We'll look at your call volume and recommend Assist, Automate, Connect — or a combination.",
    ctaButton: 'Talk to us',
  },
  fr: {
    title: 'Tarifs — Les formules ReceptionMate pour les garages',
    description: 'Trois formules ReceptionMate — Assist, Automate et Connect — comparées côte à côte. Choisissez le niveau de réceptionniste IA adapté à votre garage.',
    tiers: [
      {
        key: 'assist',
        name: 'Assist',
        tagline: 'Ne manquez plus aucun appel.',
        price: '£200',
        priceUnit: '/mois + TVA',
        priceFootnote: 'Essai gratuit 14 jours · 400 minutes incluses · £0.25 / minute supplémentaire',
        cta: 'Démarrer votre essai gratuit',
        href: '/get-started?tier=assist',
        recommended: false,
      },
      {
        key: 'automate',
        name: 'Automate',
        tagline: 'Réservez chaque intervention.',
        price: 'Sur mesure',
        priceUnit: '',
        priceFootnote: 'Selon vos succursales et intégrations',
        cta: 'Parlons d’Automate',
        href: '/get-started?tier=automate',
        recommended: true,
      },
      {
        key: 'connect',
        name: 'Connect',
        tagline: 'Entrant depuis chaque canal. Sortant qui réserve tout seul.',
        price: 'Contactez-nous',
        priceUnit: '',
        priceFootnote: 'Tarif selon le volume de contacts',
        cta: 'Parlons de Connect',
        href: '/get-started?tier=connect',
        recommended: false,
      },
    ],
    features: [
      // VOICE
      { group: 'Réceptionniste vocale', label: 'Répond à chaque appel entrant', assist: true, automate: true, connect: false },
      { group: 'Réceptionniste vocale', label: 'Recueille les coordonnées du client, du véhicule et de la prestation', assist: true, automate: true, connect: false },
      { group: 'Réceptionniste vocale', label: 'Recherche du véhicule via la DVLA pendant l’appel', detail: 'Marque, modèle, année, type de carburant, statut du contrôle technique — en temps réel.', assist: true, automate: true, connect: false },
      { group: 'Réceptionniste vocale', label: 'Vérification de l’historique du contrôle technique', assist: true, automate: true, connect: false },
      { group: 'Réceptionniste vocale', label: 'Confirmation par SMS au client', assist: true, automate: true, connect: true },
      { group: 'Réceptionniste vocale', label: 'Réserve les créneaux directement dans votre agenda', detail: 'Intégration en temps réel avec Garage Hive, Tyresoft, les calendriers et bien plus.', assist: false, automate: true, connect: false },
      { group: 'Réceptionniste vocale', label: 'Communique les tarifs de votre catalogue de prestations pendant l’appel', assist: false, automate: true, connect: false },
      { group: 'Réceptionniste vocale', label: 'Routage multi-succursales', assist: false, automate: true, connect: false },
      // MESSAGING
      { group: 'Messagerie (web + réseaux sociaux)', label: 'Widget de chat web sur le site de votre garage', assist: false, automate: false, connect: true },
      { group: 'Messagerie (web + réseaux sociaux)', label: 'Entrant WhatsApp Business', assist: false, automate: false, connect: true },
      { group: 'Messagerie (web + réseaux sociaux)', label: 'Entrant messages privés Instagram', assist: false, automate: false, connect: true },
      { group: 'Messagerie (web + réseaux sociaux)', label: 'Entrant Facebook Messenger', assist: false, automate: false, connect: true },
      { group: 'Messagerie (web + réseaux sociaux)', label: 'Rappels sortants de contrôle technique et d’entretien', detail: 'Aux clients existants ayant donné leur accord — réservation dans la même conversation.', assist: false, automate: false, connect: true },
      // PORTAL
      { group: 'Portail et rapports', label: 'Tous les appels, transcriptions et messages dans une seule boîte de réception', assist: true, automate: true, connect: true },
      { group: 'Portail et rapports', label: 'Étiquetage et recherche des conversations', assist: true, automate: true, connect: true },
      { group: 'Portail et rapports', label: 'Synthèse hebdomadaire des performances', assist: true, automate: true, connect: true },
      // SUPPORT
      { group: 'Installation et assistance', label: 'Délai de mise en service', assist: 'Quelques minutes', automate: '3 à 5 jours', connect: '3 à 5 jours' },
      { group: 'Installation et assistance', label: 'Aide à la configuration', assist: 'En autonomie', automate: 'Sur mesure', connect: 'Accompagnée' },
      { group: 'Installation et assistance', label: 'Engagement minimum', assist: 'Aucun', automate: 'Aucun', connect: 'Aucun' },
    ] as Feature[],
    groupOrder: ['Réceptionniste vocale', 'Messagerie (web + réseaux sociaux)', 'Portail et rapports', 'Installation et assistance'],
    heroKicker: 'Tarifs',
    heroH1: 'Trois formules. Choisissez celle qui vous convient.',
    heroSub: 'Toutes les formules sont facturées mensuellement. La plupart des garages commencent avec Assist ou Automate pour la partie vocale, puis ajoutent Connect lorsqu’ils sont prêts à prendre en charge la messagerie et les campagnes sortantes.',
    mostPopular: 'Le plus populaire',
    compareKicker: 'Comparer',
    compareH2: 'Ce que contient chaque formule.',
    featureCol: 'Fonctionnalité',
    tierTabs: ['Assist', 'Automate', 'Connect'],
    faqH2: 'FAQ tarifs.',
    faqs: [
      { q: 'Puis-je combiner Assist ou Automate avec Connect ?', a: 'Oui. La partie vocale (Assist ou Automate) et la partie messagerie (Connect) sont conçues pour fonctionner ensemble. La plupart des garages multicanaux commencent par l’une et ajoutent l’autre.' },
      { q: 'Que se passe-t-il si je dépasse les minutes incluses avec Assist ?', a: 'Le dépassement est facturé £0.25 par minute. Nous vous le signalons dans le portail à l’approche de l’allocation incluse, pour éviter toute surprise sur votre facture.' },
      { q: 'Pourquoi Automate est-il facturé « sur mesure » ?', a: 'Le tarif d’Automate dépend du nombre de succursales que vous gérez et des intégrations dont vous avez besoin (Garage Hive, Tyresoft, DMS sur mesure). Contactez-nous et nous vous communiquerons un montant mensuel fixe après un bref appel de cadrage.' },
      { q: 'Y a-t-il un contrat ?', a: 'Facturation mensuelle simple. Vous pouvez changer de formule à tout moment — il suffit de désactiver la règle de transfert d’appels.' },
      { q: 'Proposez-vous un essai gratuit ?', a: 'Oui — Assist inclut un essai gratuit de 14 jours. Vous renseignez votre carte à l’inscription mais vous n’êtes débité qu’au 14e jour, vous pouvez donc l’essayer sur votre vraie ligne. Annulez à tout moment avant et vous ne payez rien.' },
    ],
    ctaH2: 'Vous ne savez pas laquelle choisir ?',
    ctaSub: 'Un appel de 15 minutes avec nous suffit pour y voir clair. Nous étudierons votre volume d’appels et vous recommanderons Assist, Automate, Connect — ou une combinaison.',
    ctaButton: 'Contactez-nous',
  },
}[lang];

const tiers = c.tiers;
const features = c.features;
const groupOrder = c.groupOrder;

function renderMark(m: Mark) {
  if (typeof m === 'string') return { type: 'text', value: m };
  return m ? { type: 'yes' } : { type: 'no' };
}
---

<BaseLayout
  title={c.title}
  description={c.description}
>
  <!-- Hero -->
  <section class="bg-white pt-16 pb-10 sm:pt-20 sm:pb-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.heroKicker}</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink-900 sm:text-5xl">
        {c.heroH1}
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-ink-700">
        {c.heroSub}
      </p>
    </div>
  </section>

  <!-- Tier cards -->
  <section class="bg-ink-50 py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-6 lg:grid-cols-3 lg:items-stretch">
        {tiers.map((t) => (
          <article class={`relative flex flex-col rounded-2xl border bg-white p-6 shadow-sm transition hover:shadow-md ${t.recommended ? 'border-brand-200 ring-2 ring-brand-600 lg:-my-2' : 'border-ink-200'}`}>
            {t.recommended && (
              <span class="absolute -top-3 left-1/2 inline-flex -translate-x-1/2 items-center gap-1 rounded-full bg-brand-600 px-3 py-1 text-xs font-semibold text-white shadow">
                {c.mostPopular}
              </span>
            )}
            <h2 class="text-2xl font-bold text-ink-900">{t.name}</h2>
            <p class="mt-1 text-sm font-medium text-brand-700">{t.tagline}</p>
            <div class="mt-5 pb-5 border-b border-ink-200">
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-bold text-ink-900">{t.price}</span>
                {t.priceUnit && <span class="text-base font-medium text-ink-500">{t.priceUnit}</span>}
              </div>
              <p class="mt-1 text-xs text-ink-500">{t.priceFootnote}</p>
            </div>
            <a
              href={L(t.href, lang)}
              class={`mt-auto inline-flex w-full items-center justify-center rounded-xl px-4 py-3 text-sm font-semibold transition ${t.recommended ? 'bg-brand-600 text-white shadow-lg shadow-brand-600/25 hover:bg-brand-700' : 'border border-ink-300 bg-white text-ink-900 hover:border-brand-300 hover:text-brand-700'}`}>
              {t.cta}
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Comparison table — desktop -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">{c.compareKicker}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">
          {c.compareH2}
        </h2>
      </div>

      <!-- Desktop comparison table -->
      <div class="mt-12 hidden overflow-hidden rounded-2xl border border-ink-200 md:block">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-ink-200 bg-ink-50">
              <th scope="col" class="px-6 py-5 text-sm font-semibold text-ink-900 w-[40%]">{c.featureCol}</th>
              {tiers.map((t) => (
                <th scope="col" class="px-6 py-5 text-center">
                  <p class="text-sm font-semibold text-ink-900">{t.name}</p>
                  <p class="mt-1 text-xs text-ink-500">{t.price}{t.priceUnit}</p>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {groupOrder.map((group) => {
              const rows = features.filter((f) => f.group === group);
              return (
                <>
                  <tr class="bg-ink-50/60">
                    <th scope="rowgroup" colspan="4" class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-brand-700">
                      {group}
                    </th>
                  </tr>
                  {rows.map((row) => {
                    const a = renderMark(row.assist);
                    const au = renderMark(row.automate);
                    const co = renderMark(row.connect);
                    return (
                      <tr class="border-b border-ink-100 last:border-b-0">
                        <td class="px-6 py-4 align-top">
                          <p class="text-sm font-medium text-ink-900">{row.label}</p>
                          {row.detail && <p class="mt-0.5 text-xs text-ink-500">{row.detail}</p>}
                        </td>
                        {[a, au, co].map((m) => (
                          <td class="px-6 py-4 text-center align-top text-sm">
                            {m.type === 'yes' ? (
                              <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-brand-50 text-brand-600">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                              </span>
                            ) : m.type === 'no' ? (
                              <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-ink-100 text-ink-400">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                              </span>
                            ) : (
                              <span class="font-medium text-ink-800">{m.value}</span>
                            )}
                          </td>
                        ))}
                      </tr>
                    );
                  })}
                </>
              );
            })}
          </tbody>
        </table>
      </div>

      <!-- Mobile: skip the grid of icons (it was chaotic at narrow widths) and
           show a tabbed picker — visitor selects one tier and sees just the
           features included in it, as a clean list. Desktop's wide
           comparison table above handles the side-by-side view. -->
      <div class="mt-10 md:hidden">
        <div role="tablist" class="grid grid-cols-3 gap-2 rounded-xl bg-ink-100 p-1">
          {c.tierTabs.map((name, i) => (
            <button
              type="button"
              role="tab"
              data-tier-tab={['assist', 'automate', 'connect'][i]}
              aria-selected={i === 1 ? 'true' : 'false'}
              class={`pricing-tier-tab rounded-lg px-3 py-2 text-sm font-semibold transition ${i === 1 ? 'bg-white text-brand-700 shadow-sm' : 'text-ink-600'}`}
            >{name}</button>
          ))}
        </div>

        {['assist', 'automate', 'connect'].map((tierKey) => (
          <div
            data-tier-panel={tierKey}
            class={`pricing-tier-panel mt-5 ${tierKey === 'automate' ? '' : 'hidden'}`}
          >
            {groupOrder.map((group) => {
              const rows = features.filter((f) => f.group === group);
              const includedRows = rows.filter((r) => {
                const v = (r as any)[tierKey];
                return v === true || typeof v === 'string';
              });
              if (includedRows.length === 0) return null;
              return (
                <div class="mt-4 first:mt-0">
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-brand-700">{group}</h3>
                  <ul class="mt-2 divide-y divide-ink-100 rounded-xl border border-ink-200 bg-white">
                    {includedRows.map((row) => {
                      const v = (row as any)[tierKey];
                      const valueLabel = typeof v === 'string' ? v : null;
                      return (
                        <li class="flex items-start gap-3 px-4 py-3">
                          <span class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-50 text-brand-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                          </span>
                          <div class="min-w-0 flex-1">
                            <p class="text-sm font-medium text-ink-900">{row.label}</p>
                            {row.detail && <p class="mt-0.5 text-xs text-ink-500">{row.detail}</p>}
                            {valueLabel && <p class="mt-1 text-xs font-medium text-brand-700">{valueLabel}</p>}
                          </div>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              );
            })}
          </div>
        ))}
      </div>

      <script>
        const tabs = document.querySelectorAll<HTMLButtonElement>('.pricing-tier-tab');
        const panels = document.querySelectorAll<HTMLElement>('.pricing-tier-panel');
        tabs.forEach((tab) => {
          tab.addEventListener('click', () => {
            const key = tab.dataset.tierTab;
            tabs.forEach((t) => {
              const active = t === tab;
              t.setAttribute('aria-selected', String(active));
              t.classList.toggle('bg-white', active);
              t.classList.toggle('text-brand-700', active);
              t.classList.toggle('shadow-sm', active);
              t.classList.toggle('text-ink-600', !active);
            });
            panels.forEach((p) => p.classList.toggle('hidden', p.dataset.tierPanel !== key));
          });
        });
      </script>
    </div>
  </section>

  <!-- Pricing FAQ -->
  <section class="bg-ink-50 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold tracking-tight text-ink-900 sm:text-4xl">{c.faqH2}</h2>
      <div class="mt-8 space-y-3">
        {c.faqs.map((f) => (
          <details class="group rounded-2xl border border-ink-200 bg-white p-5 open:shadow-md">
            <summary class="cursor-pointer list-none text-base font-semibold text-ink-900">{f.q}</summary>
            <p class="mt-3 text-base leading-relaxed text-ink-700">{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-3xl bg-brand-600 p-10 text-center sm:p-14">
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">{c.ctaH2}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg text-brand-100">
          {c.ctaSub}
        </p>
        <div class="mt-8">
          <a href={L('/get-started', lang)} class="inline-flex items-center justify-center rounded-md bg-white px-6 py-3 text-base font-semibold text-brand-700 shadow-sm hover:bg-brand-50 transition">{c.ctaButton}</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
